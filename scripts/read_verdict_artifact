#!/usr/bin/env python3
"""Validate a durable verdict artifact and emit its body or delivery pointer."""

import json
import os
import re
import stat
import subprocess
import sys

from panel_common import panel_require_id


USAGE = "usage: read_verdict_artifact --id ID [--delivery] [--scope SCOPE --diff-hash HASH --run-epoch N]"
JSON_FIELDS = {"scope", "instructions", "seats", "rounds", "review_profile_path"}
PROFILE_FIELDS = {"review_profile_path", "review_profile_sha256", "review_profile_size"}
REQUIRED_FIELDS = {
    "id",
    "run_epoch",
    "status",
    "scope",
    "instructions",
    "limits",
    "seats",
    "rounds",
    "created",
    "finished",
    "diff_hash",
    "index_hash",
}


class ArtifactError(Exception):
    pass


def parse_args(argv):
    run_id = None
    scope = None
    diff_hash = None
    run_epoch = None
    delivery = False
    index = 1
    while index < len(argv):
        arg = argv[index]
        if arg in {"-h", "--help", "help"}:
            print(USAGE)
            raise SystemExit(0)
        if arg == "--delivery":
            delivery = True
            index += 1
            continue
        if arg not in {"--id", "--scope", "--diff-hash", "--run-epoch"} or index + 1 >= len(argv):
            print(USAGE, file=sys.stderr)
            raise SystemExit(2)
        value = argv[index + 1]
        if arg == "--id":
            run_id = value
        elif arg == "--scope":
            scope = value
        elif arg == "--diff-hash":
            diff_hash = value
        else:
            run_epoch = value
        index += 2
    panel_require_id(run_id or "")
    expected = (scope, diff_hash, run_epoch)
    if any(value is not None for value in expected) and not all(value is not None for value in expected):
        print(
            "read_verdict_artifact: --scope, --diff-hash, and --run-epoch must be used together",
            file=sys.stderr,
        )
        raise SystemExit(2)
    if run_epoch is not None and re.fullmatch(r"0|[1-9][0-9]*", run_epoch) is None:
        print("read_verdict_artifact: --run-epoch must be a non-negative integer", file=sys.stderr)
        raise SystemExit(2)
    return run_id, scope, diff_hash, run_epoch, delivery


def read_regular_file(path):
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    try:
        fd = os.open(path, flags)
    except OSError as error:
        raise ArtifactError("artifact is missing or unreadable") from error
    try:
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            raise ArtifactError("artifact is not a regular file")
        chunks = []
        while True:
            chunk = os.read(fd, 1024 * 1024)
            if not chunk:
                break
            chunks.append(chunk)
        return b"".join(chunks)
    finally:
        os.close(fd)


def parse_artifact(raw):
    try:
        text = raw.decode("utf-8")
    except UnicodeDecodeError as error:
        raise ArtifactError("artifact is not valid UTF-8") from error
    lines = text.splitlines(keepends=True)
    if not lines or lines[0].rstrip("\r\n") != "---":
        raise ArtifactError("artifact frontmatter is missing")
    end = next((i for i, line in enumerate(lines[1:], 1) if line.rstrip("\r\n") == "---"), None)
    if end is None:
        raise ArtifactError("artifact frontmatter is unterminated")
    fields = {}
    for line in lines[1:end]:
        stripped = line.rstrip("\r\n")
        if ": " not in stripped:
            raise ArtifactError("artifact frontmatter is malformed")
        key, value = stripped.split(": ", 1)
        if key in fields:
            raise ArtifactError(f"artifact frontmatter repeats {key}")
        fields[key] = value
    missing = sorted(REQUIRED_FIELDS - fields.keys())
    if missing:
        raise ArtifactError(f"artifact frontmatter is missing {missing[0]}")
    for key in JSON_FIELDS & fields.keys():
        try:
            fields[key] = json.loads(fields[key])
        except (json.JSONDecodeError, TypeError) as error:
            raise ArtifactError(f"artifact frontmatter has invalid {key}") from error
        if not isinstance(fields[key], str):
            raise ArtifactError(f"artifact frontmatter has invalid {key}")
    body = "".join(lines[end + 1 :])
    if body.startswith("\r\n"):
        body = body[2:]
    elif body.startswith("\n"):
        body = body[1:]
    if not body:
        raise ArtifactError("artifact verdict body is empty")
    return fields, body


def validate(fields, run_id, expected_scope, expected_hash, expected_epoch, allow_incomplete=False):
    if fields["id"] != run_id:
        raise ArtifactError("artifact id does not match the requested run")
    if fields["status"] != "finished" and not (allow_incomplete and fields["status"] == "incomplete"):
        raise ArtifactError("artifact is not a finished review")
    if re.fullmatch(r"0|[1-9][0-9]*", fields["run_epoch"]) is None:
        raise ArtifactError("artifact run_epoch is invalid")
    limits = re.fullmatch(r"issue-rounds=([1-9][0-9]*) max-rounds=([1-9][0-9]*)", fields["limits"])
    if limits is None or int(limits.group(1)) > int(limits.group(2)):
        raise ArtifactError("artifact limits are invalid")
    timestamp = r"[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}"
    if re.fullmatch(timestamp, fields["created"]) is None or re.fullmatch(timestamp, fields["finished"]) is None:
        raise ArtifactError("artifact timestamps are invalid")
    if not fields["scope"]:
        raise ArtifactError("artifact scope is empty")
    if not re.fullmatch(r"[0-9a-f]{64}", fields["diff_hash"]):
        raise ArtifactError("artifact diff_hash is invalid")
    if not re.fullmatch(r"[0-9a-f]{64}", fields["index_hash"]):
        raise ArtifactError("artifact index_hash is invalid")
    present_profile_fields = PROFILE_FIELDS & fields.keys()
    if present_profile_fields and present_profile_fields != PROFILE_FIELDS:
        raise ArtifactError("artifact review profile metadata is incomplete")
    if present_profile_fields:
        if not fields["review_profile_path"].startswith("/"):
            raise ArtifactError("artifact review_profile_path is invalid")
        if not re.fullmatch(r"[0-9a-f]{64}", fields["review_profile_sha256"]):
            raise ArtifactError("artifact review_profile_sha256 is invalid")
        if re.fullmatch(r"[1-9][0-9]*", fields["review_profile_size"]) is None:
            raise ArtifactError("artifact review_profile_size is invalid")
        if int(fields["review_profile_size"]) > 64 * 1024:
            raise ArtifactError("artifact review_profile_size is invalid")
    if expected_scope is not None and fields["scope"] != expected_scope:
        raise ArtifactError("artifact scope does not match the requested run")
    if expected_hash is not None and fields["diff_hash"] != expected_hash:
        raise ArtifactError("artifact diff_hash does not match the requested run")
    if expected_epoch is not None and fields["run_epoch"] != expected_epoch:
        raise ArtifactError("artifact run_epoch does not match the requested run")


def read_retained_delivery_status(run_id):
    path = f"/tmp/{run_id}/index.json"
    if not os.path.exists(path):
        return None
    try:
        result = subprocess.run(
            [os.path.join(os.path.dirname(__file__), "index"), "delivery-status", run_id],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError as error:
        raise ArtifactError("retained index delivery status is unavailable") from error
    if result.returncode != 0:
        raise ArtifactError("retained index is malformed")
    try:
        status = json.loads(result.stdout)
    except json.JSONDecodeError as error:
        raise ArtifactError("retained index delivery status is malformed") from error
    required = {"index_hash", "run_epoch", "phase", "open", "low_only", "unresolved", "contested"}
    if (
        not isinstance(status, dict)
        or set(status) != required
        or not re.fullmatch(r"[0-9a-f]{64}", status.get("index_hash", ""))
        or not isinstance(status.get("run_epoch"), int)
        or isinstance(status.get("run_epoch"), bool)
        or status["run_epoch"] < 0
        or status.get("phase") not in {"round0", "debate"}
        or any(
            not isinstance(status.get(key), int)
            or isinstance(status.get(key), bool)
            or status[key] < 0
            for key in ("open", "unresolved", "contested")
        )
        or not isinstance(status.get("low_only"), bool)
    ):
        raise ArtifactError("retained index delivery status is malformed")
    return status


def delivery_text(fields, run_id):
    status = read_retained_delivery_status(run_id)
    if fields["status"] == "incomplete":
        if status is None or status["phase"] != "debate":
            raise ArtifactError("incomplete artifact is not a low-severity gate")
        if str(status["run_epoch"]) != fields["run_epoch"]:
            raise ArtifactError("retained index run_epoch does not match the artifact")
        if status["index_hash"] != fields["index_hash"]:
            raise ArtifactError("retained index does not match the artifact")
        if status["open"] == 0 or not status["low_only"]:
            raise ArtifactError("incomplete artifact is not a low-severity gate")
        return (
            "Review paused because only low-severity findings remain. Report snapshot: "
            f"/tmp/{run_id}.md\n"
        )
    lines = [f"Done. Final report: /tmp/{run_id}.md"]
    if status is None:
        return "\n".join(lines) + "\n"
    if str(status["run_epoch"]) != fields["run_epoch"]:
        raise ArtifactError("retained index run_epoch does not match the artifact")
    if status["index_hash"] != fields["index_hash"]:
        raise ArtifactError("retained index does not match the artifact")
    unresolved = status["unresolved"]
    contested = status["contested"]
    if unresolved or contested:
        lines.append(
            f"{unresolved} unresolved, {contested} contested remain — run panel-review:continue "
            "[unresolved|contested] to debate them further, or panel-review:discard "
            "to remove the saved review."
        )
    return "\n".join(lines) + "\n"


def result_text(fields, body):
    if not PROFILE_FIELDS <= fields.keys():
        return body
    return (
        f"Review profile: {fields['review_profile_path']}\n"
        f"SHA-256: {fields['review_profile_sha256']}\n\n"
        f"{body}"
    )


def main(argv):
    run_id, expected_scope, expected_hash, expected_epoch, delivery = parse_args(argv)
    try:
        fields, body = parse_artifact(read_regular_file(f"/tmp/{run_id}.md"))
        validate(fields, run_id, expected_scope, expected_hash, expected_epoch, allow_incomplete=delivery)
    except ArtifactError as error:
        print(f"read_verdict_artifact: {error}", file=sys.stderr)
        return 1
    if delivery:
        try:
            sys.stdout.write(delivery_text(fields, run_id))
        except ArtifactError as error:
            print(f"read_verdict_artifact: {error}", file=sys.stderr)
            return 1
    else:
        sys.stdout.write(result_text(fields, body))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
