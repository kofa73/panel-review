#!/usr/bin/env python3
"""Merge a referee addendum into a commit-sweep payload."""

import json
import os
import sys


def jq_default(value, fallback):
    """Implement jq's `//` default for null and false values."""
    return fallback if value is None or value is False else value


def last_by(entries, key):
    groups = {}
    for entry in entries:
        groups[key(entry)] = entry
    return [groups[group_key] for group_key in sorted(groups)]


def merge_revisions(entries):
    groups = {}
    for entry in entries:
        issue_id = entry["id"]
        if issue_id not in groups:
            groups[issue_id] = {}
        groups[issue_id].update(entry["fields"])
    return [{"id": issue_id, "fields": groups[issue_id]} for issue_id in sorted(groups)]


def merge(base, addendum):
    payload = {
        "bump": sorted(set(jq_default(base.get("bump"), []) + jq_default(addendum.get("bump"), []))),
        "set_state": last_by(
            jq_default(base.get("set_state"), []) + jq_default(addendum.get("set_state"), []),
            lambda entry: entry["id"],
        ),
        "set_flag": last_by(
            jq_default(base.get("set_flag"), []) + jq_default(addendum.get("set_flag"), []),
            lambda entry: (entry["id"], entry["flag"]),
        ),
        "revise": merge_revisions(jq_default(base.get("revise"), []) + jq_default(addendum.get("revise"), [])),
        "add_evidence": jq_default(base.get("add_evidence"), []) + jq_default(addendum.get("add_evidence"), []),
        "add_issues": jq_default(base.get("add_issues"), []) + jq_default(addendum.get("add_issues"), []),
        "evaluated_by": {
            **jq_default(base.get("evaluated_by"), {}),
            **jq_default(addendum.get("evaluated_by"), {}),
        },
    }
    return {key: value for key, value in payload.items() if len(value) > 0}


def read_object(raw, label):
    try:
        value = json.loads(raw)
    except (UnicodeDecodeError, json.JSONDecodeError):
        print(f"merge_payload: {label} is not a JSON object", file=sys.stderr)
        return None
    if type(value) is not dict:
        print(f"merge_payload: {label} is not a JSON object", file=sys.stderr)
        return None
    return value


def shape_error(label, payload):
    """Report the first structural violation in a payload, or None if well-formed.

    Guards the exact keys merge() dereferences below, so a hand-built addendum with
    the wrong shape (e.g. a `revise` entry with a flat `claim` instead of the
    `fields` wrapper) yields an actionable message + exit 2 here, instead of an
    uncaught KeyError that prints a traceback and (via the caller's redirect) can
    truncate the payload it was meant to produce.
    """
    def entries(key):
        value = jq_default(payload.get(key), [])
        if type(value) is not list:
            return None, f"merge_payload: {label} .{key} is not a list"
        return value, None

    for key, required in (
        ("bump", ()),
        ("set_state", ("id",)),
        ("set_flag", ("id", "flag")),
        ("revise", ("id", "fields")),
    ):
        items, err = entries(key)
        if err:
            return err
        for entry in items:
            if key == "bump":
                continue
            if type(entry) is not dict:
                return f'merge_payload: {label} .{key} entry is not an object: {entry!r}'
            for field in required:
                if field not in entry:
                    return f'merge_payload: {label} .{key} entry missing "{field}": {entry!r}'
            if key == "revise" and type(entry["fields"]) is not dict:
                return f'merge_payload: {label} .revise entry "fields" is not an object: {entry!r}'
    return None


def main(argv):
    if len(argv) < 2:
        print("usage: merge_payload <base.json>   (addendum on stdin)", file=sys.stderr)
        return 2

    base_path = argv[1]
    if not os.path.isfile(base_path):
        print(f"merge_payload: no such base file: {base_path}", file=sys.stderr)
        return 1
    try:
        with open(base_path, "r", encoding="utf-8") as handle:
            base = read_object(handle.read(), "base")
    except OSError:
        print(f"merge_payload: no such base file: {base_path}", file=sys.stderr)
        return 1
    if base is None:
        return 2

    addendum_raw = sys.stdin.read().rstrip("\n")
    addendum = read_object(addendum_raw or "{}", "addendum")
    if addendum is None:
        return 2

    for label, payload in (("base", base), ("addendum", addendum)):
        err = shape_error(label, payload)
        if err:
            print(err, file=sys.stderr)
            return 2

    print(json.dumps(merge(base, addendum), separators=(",", ":"), ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
