#!/usr/bin/env bash
# merge_payload — combine the referee's judgment additions into the mechanical
# round payload from `decide_round`, with the per-key semantics `index
# commit-sweep` requires. The referee must NEVER append a 2nd set_state/revise
# for an id (commit-sweep rejects duplicate state/flag/revise targets and leaves
# the round uncommitted) — it folds additions in here instead.
#
# Usage:  merge_payload <base.json>           # addendum (a payload-shaped object) on stdin
#         -> merged payload on stdout
#
# Both base and addendum are commit-sweep payloads (any subset of keys). Merge:
#   bump          union, unique
#   set_state     by id; ADDENDUM WINS (so folding a new finding can reopen an
#                 issue decide_round just terminated: addendum {id,state:"open"})
#   set_flag      by (id,flag); addendum wins
#   revise        by id; FIELDS deep-merged (base.fields + addendum.fields), so a
#                 referee-synthesized `claim` joins decide_round's enum `severity`
#                 on the SAME issue instead of becoming a duplicate revise entry
#   add_evidence  concatenated (append)
#   add_issues    concatenated (append)
#   evaluated_by  merged by issue id; addendum values replace base values
# Empty arrays are dropped. Output still goes through `index commit-sweep`, which
# re-validates everything.
set -euo pipefail
command -v jq >/dev/null 2>&1 || { echo "merge_payload: jq not found" >&2; exit 127; }

[ "$#" -ge 1 ] || { echo "usage: merge_payload <base.json>   (addendum on stdin)" >&2; exit 2; }
base="$1"
[ -f "$base" ] || { echo "merge_payload: no such base file: $base" >&2; exit 1; }
jq -e 'type=="object"' "$base" >/dev/null 2>&1 || { echo "merge_payload: base is not a JSON object" >&2; exit 2; }

add="$(cat)"; [ -n "$add" ] || add='{}'
printf '%s' "$add" | jq -e 'type=="object"' >/dev/null 2>&1 || { echo "merge_payload: addendum is not a JSON object" >&2; exit 2; }

jq -n --slurpfile b "$base" --argjson add "$add" '
  ($b[0]) as $base |
  # base entries first, addendum second; jq group_by is stable, so `last` per
  # group == the addendum (addendum wins). revise additionally deep-merges fields.
  {
    bump:        ((($base.bump // []) + ($add.bump // [])) | unique),
    set_state:   ((($base.set_state // []) + ($add.set_state // [])) | group_by(.id) | map(last)),
    set_flag:    ((($base.set_flag  // []) + ($add.set_flag  // [])) | group_by("\(.id) \(.flag)") | map(last)),
    revise:      ((($base.revise    // []) + ($add.revise    // [])) | group_by(.id)
                  | map({id: .[0].id, fields: (map(.fields) | add)})),
    add_evidence:(($base.add_evidence // []) + ($add.add_evidence // [])),
    add_issues:  (($base.add_issues // []) + ($add.add_issues // [])),
    evaluated_by:(($base.evaluated_by // {}) + ($add.evaluated_by // {}))
  }
  | with_entries(select(.value | length > 0))
'
