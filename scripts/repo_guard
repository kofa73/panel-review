#!/usr/bin/env bash
# repo_guard — keep the code under review byte-for-byte unchanged across a run.
#
# The seats now run with write access (Codex's sandbox is bypassed so its MCP/
# tilth calls work and it can write scratch files; agy was always a full tool
# user). Instead of trusting each seat's own sandbox to stay read-only, we take a
# snapshot of the TRACKED working tree at the start of the review and, after every
# seat pass, detect and auto-revert any tracked-file drift — then flag it loudly in
# the verdict's Process notes. Untracked scratch (the seats' own work dirs, the
# .panel-review/ card cache) is deliberately left alone.
#
# Usage:
#   repo_guard snapshot --id <id> --workdir <dir>
#       Record a baseline for <dir>: a `git stash create` commit SHA (captures the
#       tracked+staged working-tree bytes WITHOUT touching the tree; empty when the
#       tree is clean -> baseline falls back to HEAD) plus a sha256 manifest of every
#       tracked file. Written under /tmp/<id>/guard/.
#   repo_guard verify --id <id> --workdir <dir> [--restore]
#       Re-hash the tracked files and compare to the snapshot. Print each drifted
#       path (modified/deleted/added) on stdout. With --restore, restore every
#       drifted tracked file from the baseline (`git checkout <baseline> -- <path>`).
#       Exit nonzero when any drift was found (0 = clean).
#
# Protects TRACKED-FILE CONTENT ONLY. A baseline taken on a dirty tree restores the
# DIRTY bytes (the state at snapshot time), not HEAD — the review must see exactly
# what it started with. Standalone: jq is not needed; git + sha256sum + bash are.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_panel_common.sh
. "$here/_panel_common.sh"

cmd="${1-}"; shift || true
id=""; workdir=""; restore=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --id) id="${2-}"; shift 2 ;;
    --workdir) workdir="${2-}"; shift 2 ;;
    --restore) restore=1; shift ;;
    *) echo "repo_guard: unknown arg: $1" >&2; exit 2 ;;
  esac
done

panel_require_id "$id"
[ -n "$workdir" ] && [ -d "$workdir" ] || { echo "repo_guard: missing/invalid --workdir" >&2; exit 2; }
git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
  || { echo "repo_guard: $workdir is not a git work tree" >&2; exit 2; }

guarddir="/tmp/$id/guard"

# Hash every tracked file into <out> as "<sha256>\t<path>" lines. ls-files -z is
# null-delimited so spaces in paths survive; we hash from STDIN (sha256sum < file)
# so the path never appears in sha256sum's output (no `\`-escaping, no filename
# parsing). A tracked file absent on disk (e.g. `rm` without `git rm`) is recorded
# as the literal hash "ABSENT" so verify still sees it as drift. Pathological names
# containing a tab or newline are not supported (none exist in this repo).
hash_tracked() {
  local wd="$1" out="$2" f h
  : > "$out"
  while IFS= read -r -d '' f; do
    if [ -f "$wd/$f" ]; then
      h="$(sha256sum < "$wd/$f" | cut -d' ' -f1)"
    else
      h="ABSENT"
    fi
    printf '%s\t%s\n' "$h" "$f" >> "$out"
  done < <(git -C "$wd" ls-files -z)
}

case "$cmd" in
  snapshot)
    mkdir -p "$guarddir"
    # `git stash create` builds a dangling commit from the current index+worktree
    # WITHOUT modifying either; empty output means the tree is clean, so the safe
    # restore source is HEAD. Either way the SHA is a valid `git checkout` source
    # for the duration of the run (not garbage-collected while referenced here).
    baseline="$(git -C "$workdir" stash create 2>/dev/null || true)"
    if [ -z "$baseline" ]; then
      baseline="$(git -C "$workdir" rev-parse --verify HEAD 2>/dev/null || true)"
    fi
    printf '%s\n' "$baseline" > "$guarddir/baseline"
    hash_tracked "$workdir" "$guarddir/manifest.sha256"
    echo "repo_guard: snapshot ${id} (baseline=${baseline:-<none>}, $(wc -l < "$guarddir/manifest.sha256") tracked files)"
    ;;

  verify)
    [ -f "$guarddir/manifest.sha256" ] || { echo "repo_guard: no snapshot for $id" >&2; exit 2; }
    baseline="$(cat "$guarddir/baseline" 2>/dev/null || true)"
    cur="$(mktemp "${TMPDIR:-/tmp}/repo_guard.XXXXXX")"
    trap 'rm -f "$cur"' EXIT
    hash_tracked "$workdir" "$cur"

    declare -A old new
    while IFS=$'\t' read -r h f; do old["$f"]="$h"; done < "$guarddir/manifest.sha256"
    while IFS=$'\t' read -r h f; do new["$f"]="$h"; done < "$cur"

    drift=()
    for f in "${!old[@]}"; do
      if [ -z "${new[$f]+x}" ]; then
        drift+=("deleted: $f")                       # un-tracked since snapshot (git rm)
      elif [ "${old[$f]}" != "${new[$f]}" ]; then
        drift+=("modified: $f")                       # content changed (or now ABSENT)
      fi
    done
    for f in "${!new[@]}"; do
      [ -z "${old[$f]+x}" ] && drift+=("added: $f")    # newly tracked since snapshot
    done

    if [ "${#drift[@]}" -eq 0 ]; then
      exit 0
    fi

    printf '%s\n' "${drift[@]}"
    if [ "$restore" -eq 1 ]; then
      if [ -z "$baseline" ]; then
        echo "repo_guard: cannot restore — no baseline recorded" >&2
      else
        for d in "${drift[@]}"; do
          f="${d#*: }"
          # `added` files do not exist in the baseline; checkout is a no-op error
          # there (left in place, still reported). modified/deleted restore cleanly.
          git -C "$workdir" checkout "$baseline" -- "$f" 2>/dev/null \
            || echo "repo_guard: could not restore $f from baseline" >&2
        done
      fi
    fi
    exit 1
    ;;

  *)
    echo "usage: repo_guard {snapshot|verify} --id <id> --workdir <dir> [--restore]" >&2
    exit 2
    ;;
esac
