#!/usr/bin/env bash
# run_seat — dispatch ONE external CLI seat (Codex or Gemini) for one tag and parse
# its block. It wraps the byte-exact dispatch→parse the referee would otherwise
# hand-roll for every seat, in every round (SKILL Round 0 step 4, debate step 6):
# pick the right CLI wrapper, feed it the prompt, capture its verbatim output, and
# run parse_block. The Claude seat is NOT here: it is a fresh subagent the referee
# spawns via the Agent tool, not a CLI — only the two CLI seats are scriptable.
#
# It does NOT repair. Salvaging a slipped block (a malformed fence, or a real review
# the seat forgot to fence) is the REFEREE's job now, not a script's: the seat that
# wrote the block is gone after it exits, so any "repair" re-dispatch is a fresh,
# cold model instance whose only input is the raw file on disk — the exact same
# input the referee has, and the referee is the mind that must consume the findings
# anyway. So there is no informational reason to route the fix through a redundant
# extra seat, and deciding "is this a real review or a down-seat stub?" is an LLM
# judgment, not a grep heuristic. On a non-engaged status the referee reads that one
# seat's raw and rewrites it well-formed (see SKILL "Salvage"); this script just
# reports what parse_block found.
#
# Usage:
#   run_seat --seat <codex|gemini> --tag <findings|new_findings|stances> \
#            --prompt <promptfile> --raw <rawfile> --parsed <parsedfile> [--label <label>]
#
#   --prompt   the assembled prompt for this pass (stdin to the CLI).
#   --raw      where the seat's verbatim response is written (never overwritten here —
#              in debate, `stances` and `new_findings` share this one raw and `sweep
#              ingest-batch` re-reads it, so run_seat leaves it exactly as the seat
#              produced it).
#   --parsed   where the validated JSONL is written (parse_block output, _source-tagged).
#   --label    _source tag for parse_block (default: the seat name).
#
# Output: the parse_block status on stdout (0 engaged · 4 no block/down · 5 malformed).
# The script's own exit is 0 unless a usage/setup error occurred (2 usage, 1 missing
# file) — so the caller reads engagement from stdout, never conflated with the
# wrapper's own failure.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"

seat=""; tag=""; prompt=""; raw=""; parsed=""; label=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --seat)      seat="${2-}"; shift 2 ;;
    --tag)       tag="${2-}"; shift 2 ;;
    --prompt)    prompt="${2-}"; shift 2 ;;
    --raw)       raw="${2-}"; shift 2 ;;
    --parsed)    parsed="${2-}"; shift 2 ;;
    --label)     label="${2-}"; shift 2 ;;
    *) echo "run_seat: unknown arg: $1" >&2; exit 2 ;;
  esac
done
case "$seat" in
  codex)  cli="$here/run_codex" ;;
  gemini) cli="$here/run_agy" ;;
  *) echo "run_seat: --seat must be codex|gemini (the Claude seat is a subagent, not a CLI)" >&2; exit 2 ;;
esac
case "$tag" in findings|new_findings|stances) ;; *) echo "run_seat: --tag must be findings|new_findings|stances" >&2; exit 2 ;; esac
case "$tag" in findings) phase=round0 ;; *) phase=debate ;; esac
[ -n "$prompt" ] && [ -f "$prompt" ] || { echo "run_seat: --prompt must name an existing file" >&2; exit 1; }
[ -n "$raw" ]    || { echo "run_seat: --raw required" >&2; exit 2; }
[ -n "$parsed" ] || { echo "run_seat: --parsed required" >&2; exit 2; }
[ -n "$label" ] || label="$seat"

# Dispatch the seat, capturing its output to the raw file and never aborting on a
# seat failure (a down seat = empty/partial output = parse_block exit 4; we degrade,
# not crash). The CLI wrapper's own stderr passes through to ours for logging.
set +e
"$cli" < "$prompt" > "$raw"
set -e

# Parse the block; its exit status (0 engaged · 4 no block · 5 malformed) is the
# engagement signal the caller reads from stdout.
set +e
"$here/parse_block" --response "$phase" "$tag" "$raw" "$label" > "$parsed"
status=$?
set -e

printf '%s\n' "$status"
