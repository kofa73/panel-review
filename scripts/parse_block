#!/usr/bin/env python3
import sys
import os
import json
import subprocess
import re

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from panel_common import CATEGORIES, SEVERITIES, valid_location, valid_point

def compact_json(obj):
    return json.dumps(obj, separators=(',', ':'), ensure_ascii=False)

def ok_object(obj): return isinstance(obj, dict)
def ok_claim(obj): return isinstance(obj.get("claim"), str)
def ok_location(obj): return "location" in obj and valid_location(obj["location"])
def ok_category(obj): return isinstance(obj.get("category"), str) and obj.get("category") in CATEGORIES
def ok_severity(obj): return isinstance(obj.get("severity"), str) and obj.get("severity") in SEVERITIES

def normalize_points(obj):
    points = obj.get("points", [])
    if isinstance(points, list):
        return [p for p in points if valid_point(p)]
    elif valid_point(points):
        return [points]
    return []

def ok_points(obj):
    return len(normalize_points(obj)) > 0

def ok_id(obj): return isinstance(obj.get("id"), str)
def ok_stance(obj):
    return isinstance(obj.get("stance"), str) and bool(re.match(r"^(support|support_with_revision|reject)$", obj.get("stance", "")))

def diag_findings(obj):
    if not ok_object(obj): return "not a JSON object"
    if not ok_claim(obj): return "missing or non-string field `claim`"
    if not ok_location(obj): return "missing/invalid `location` (a non-empty \"file:line\" string, or an array of such)"
    if not ok_category(obj): return "missing/invalid `category` (one of: security, correctness, performance, maintainability, style)"
    if not ok_severity(obj): return "missing/invalid `severity` (one of: critical, high, medium, low, style)"
    if not ok_points(obj): return "no valid `points[]`: every finding needs a non-empty points array; each point needs a string `assertion` and a valid `location` (do not put precondition/impact at the top level)"
    return "valid"

def valid_findings(obj):
    if ok_object(obj) and ok_claim(obj) and ok_location(obj) and ok_category(obj) and ok_severity(obj):
        points = normalize_points(obj)
        if len(points) > 0:
            obj["points"] = points
            return True, obj
    return False, None

def diag_stances(obj):
    if not ok_object(obj): return "not a JSON object"
    if not ok_id(obj): return "missing or non-string field `id`"
    if not ok_stance(obj): return "missing/invalid `stance` (one of: support, support_with_revision, reject)"
    return "valid"

def valid_stances(obj):
    if not (ok_object(obj) and ok_id(obj) and ok_stance(obj)):
        return False, None

    if "revision" in obj:
        if isinstance(obj["revision"], dict):
            rev = obj["revision"]
            new_rev = {}
            for k in list(rev.keys()):
                if k not in {"category", "severity", "claim", "location"}:
                    continue
                val = rev[k]
                if k == "category" and not (isinstance(val, str) and val in CATEGORIES):
                    continue
                if k == "severity" and not (isinstance(val, str) and val in SEVERITIES):
                    continue
                if k == "claim" and not isinstance(val, str):
                    continue
                if k == "location" and not valid_location(val):
                    continue
                new_rev[k] = val
            if len(new_rev) == 0:
                del obj["revision"]
            else:
                obj["revision"] = new_rev
        else:
            del obj["revision"]

    if "new_evidence" in obj:
        if isinstance(obj["new_evidence"], dict) and valid_point(obj["new_evidence"]):
            pass
        else:
            del obj["new_evidence"]

    if "evidence" in obj:
        if isinstance(obj["evidence"], dict) and valid_point(obj["evidence"]):
            pass
        else:
            del obj["evidence"]

    return True, obj

def diag_default(obj):
    if ok_object(obj): return "valid"
    return "not a JSON object"

def valid_default(obj):
    if ok_object(obj):
        return True, obj
    return False, None

def get_rules(tag):
    if tag in ("findings", "new_findings"):
        return valid_findings, diag_findings
    elif tag == "stances":
        return valid_stances, diag_stances
    else:
        return valid_default, diag_default

def main():
    if len(sys.argv) < 2:
        print("usage: parse_block [--diagnose] <tag> <rawfile> [label]", file=sys.stderr)
        sys.exit(2)

    args = sys.argv[1:]
    diagnose = False
    if args and args[0] == "--diagnose":
        diagnose = True
        args = args[1:]

    if len(args) < 2:
        print("usage: parse_block [--diagnose] <tag> <rawfile> [label]", file=sys.stderr)
        sys.exit(2)

    tag = args[0]
    file_path = args[1]
    label = args[2] if len(args) > 2 else ""

    if not diagnose and label:
        pass
    else:
        label = ""

    if not os.path.isfile(file_path):
        print(f"parse_block: no such file: {file_path}", file=sys.stderr)
        sys.exit(1)

    here = os.path.dirname(os.path.abspath(__file__))
    extract_bin = os.path.join(here, "extract_block")

    # 1. extract_block --present
    res = subprocess.run([extract_bin, "--present", tag, file_path])
    if res.returncode != 0:
        print(f"parse_block: no '{tag}' block in output (seat produced none)", file=sys.stderr)
        sys.exit(4)

    # 2. Extract inner content
    res = subprocess.run([extract_bin, tag, file_path], stdout=subprocess.PIPE, text=True, check=True)
    raw = res.stdout

    # 3. If empty or whitespace-only -> exit 0
    if not raw.strip():
        sys.exit(0)

    # 4. Try whole-block JSON decode
    parsed_whole = False
    lines_to_process = []

    decoder = json.JSONDecoder()
    pos = 0
    items = []
    stream_success = True

    while pos < len(raw):
        match = re.match(r'\s*', raw[pos:])
        if match:
            pos += match.end()
        if pos == len(raw):
            break
        try:
            obj, idx = decoder.raw_decode(raw[pos:])
            items.append(obj)
            pos += idx
        except json.JSONDecodeError:
            stream_success = False
            break

    if stream_success:
        parsed_whole = True
        flattened = []
        for item in items:
            if isinstance(item, list):
                flattened.extend(item)
            else:
                flattened.append(item)
        for item in flattened:
            lines_to_process.append(compact_json(item))
    else:
        for line in raw.split('\n'):
            if line.strip():
                lines_to_process.append(line)

    valid_func, diag_func = get_rules(tag)
    n = 0
    bad = 0
    item_count = 0

    for line in lines_to_process:
        if diagnose:
            item_count += 1
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                bad += 1
                print(f"item {item_count}: not valid JSON (syntax error)")
                print(f"    >>> {line}")
                continue

            try:
                reason = diag_func(obj)
            except Exception:
                reason = "could not evaluate (unexpected shape)"

            if reason != "valid":
                bad += 1
                print(f"item {item_count}: {reason}")
                print(f"    >>> {line}")
            continue

        # Normal mode
        try:
            obj = json.loads(line)
            is_valid, norm_obj = valid_func(obj)
            if is_valid:
                n += 1
                if label:
                    norm_obj["_source"] = label
                    norm_obj["fid"] = f"{label}-{n}"
                print(compact_json(norm_obj))
            else:
                bad += 1
        except json.JSONDecodeError:
            bad += 1

    if diagnose:
        print(f"parse_block --diagnose '{tag}': {item_count} item(s), {bad} invalid", file=sys.stderr)
        if bad == 0:
            sys.exit(0)
        else:
            sys.exit(5)

    if bad > 0:
        print(f"parse_block: skipped {bad} malformed line(s) in '{tag}'", file=sys.stderr)

    if n == 0:
        print("parse_block: block present with non-whitespace content but zero valid objects parsed", file=sys.stderr)
        sys.exit(5)

    sys.exit(0)

if __name__ == "__main__":
    main()
