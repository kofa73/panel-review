#!/usr/bin/env python3
import sys
import os
import json
import subprocess
import re

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from seat_contract import get_rules, response_problem

def compact_json(obj):
    return json.dumps(obj, separators=(',', ':'), ensure_ascii=False)

def main():
    if len(sys.argv) < 2:
        print("usage: parse_block [--diagnose] [--response <round0|debate>] <tag> <rawfile> [label]", file=sys.stderr)
        sys.exit(2)

    args = sys.argv[1:]
    diagnose = False
    response_phase = None
    while args and args[0].startswith("--"):
        if args[0] == "--diagnose":
            diagnose = True
            args = args[1:]
        elif args[0] == "--response" and len(args) >= 2:
            response_phase = args[1]
            args = args[2:]
        else:
            print("usage: parse_block [--diagnose] [--response <round0|debate>] <tag> <rawfile> [label]", file=sys.stderr)
            sys.exit(2)

    if len(args) < 2:
        print("usage: parse_block [--diagnose] [--response <round0|debate>] <tag> <rawfile> [label]", file=sys.stderr)
        sys.exit(2)

    tag = args[0]
    file_path = args[1]
    label = args[2] if len(args) > 2 else ""

    if not diagnose and label:
        pass
    else:
        label = ""

    if not os.path.isfile(file_path):
        print(f"parse_block: no such file: {file_path}", file=sys.stderr)
        sys.exit(1)

    if response_phase is not None:
        try:
            with open(file_path, encoding="utf-8", errors="replace") as handle:
                problem = response_problem(handle.read(), response_phase)
        except ValueError as error:
            print(f"parse_block: {error}", file=sys.stderr)
            sys.exit(2)
        if problem is not None:
            code, message = problem
            print(f"parse_block: {message}", file=sys.stderr)
            sys.exit(code)

    here = os.path.dirname(os.path.abspath(__file__))
    extract_bin = os.path.join(here, "extract_block")

    # 1. extract_block --present
    res = subprocess.run([extract_bin, "--present", tag, file_path])
    if res.returncode != 0:
        print(f"parse_block: no '{tag}' block in output (seat produced none)", file=sys.stderr)
        sys.exit(4)

    # 2. Extract inner content
    res = subprocess.run([extract_bin, tag, file_path], stdout=subprocess.PIPE, text=True, check=True)
    raw = res.stdout

    # 3. If empty or whitespace-only -> exit 0
    if not raw.strip():
        sys.exit(0)

    # 4. Try whole-block JSON decode
    parsed_whole = False
    lines_to_process = []

    decoder = json.JSONDecoder()
    pos = 0
    items = []
    stream_success = True

    while pos < len(raw):
        match = re.match(r'\s*', raw[pos:])
        if match:
            pos += match.end()
        if pos == len(raw):
            break
        try:
            obj, idx = decoder.raw_decode(raw[pos:])
            items.append(obj)
            pos += idx
        except json.JSONDecodeError:
            stream_success = False
            break

    if stream_success:
        parsed_whole = True
        flattened = []
        for item in items:
            if isinstance(item, list):
                flattened.extend(item)
            else:
                flattened.append(item)
        for item in flattened:
            lines_to_process.append(compact_json(item))
    else:
        for line in raw.split('\n'):
            if line.strip():
                lines_to_process.append(line)

    valid_func, diag_func = get_rules(tag)
    n = 0
    bad = 0
    item_count = 0

    for line in lines_to_process:
        if diagnose:
            item_count += 1
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                bad += 1
                print(f"item {item_count}: not valid JSON (syntax error)")
                print(f"    >>> {line}")
                continue

            try:
                reason = diag_func(obj)
            except Exception:
                reason = "could not evaluate (unexpected shape)"

            if reason != "valid":
                bad += 1
                print(f"item {item_count}: {reason}")
                print(f"    >>> {line}")
            continue

        # Normal mode
        try:
            obj = json.loads(line)
            is_valid, norm_obj = valid_func(obj)
            if is_valid:
                n += 1
                if label:
                    norm_obj["_source"] = label
                    norm_obj["fid"] = f"{label}-{n}"
                print(compact_json(norm_obj))
            else:
                bad += 1
        except json.JSONDecodeError:
            bad += 1

    if diagnose:
        print(f"parse_block --diagnose '{tag}': {item_count} item(s), {bad} invalid", file=sys.stderr)
        if bad == 0:
            sys.exit(0)
        else:
            sys.exit(5)

    if bad > 0:
        print(f"parse_block: skipped {bad} malformed line(s) in '{tag}'", file=sys.stderr)

    # n == 0 with bad == 0 means the block decoded cleanly to ZERO items — an explicit
    # empty array `[]` (or empty stream). That is a legitimate "nothing" (a required-
    # emptyable `new_findings`, or a seat that found nothing), NOT a malformed block, so
    # it must exit 0 to match `--diagnose`/check_draft (which already treats `[]` as
    # valid). Exit 5 is reserved for content that was present but wholly unparseable
    # (bad > 0, nothing valid survived).
    if n == 0 and bad > 0:
        print("parse_block: block present with non-whitespace content but zero valid objects parsed", file=sys.stderr)
        sys.exit(5)

    sys.exit(0)

if __name__ == "__main__":
    main()
