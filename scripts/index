#!/usr/bin/env python3
"""The canonical, locked writer for /tmp/<ID>/index.json."""

import copy
import fcntl
import json
import os
import sys

from panel_common import (
    CATEGORIES,
    SEVERITIES,
    STATES,
    panel_atomic_write,
    panel_require_id,
    panel_valid_id,
    valid_location,
    valid_point,
)


FLAGS = {"peer_reviewed", "fully_vetted", "detail_contested"}
PAYLOAD_KEYS = {"add_issues", "bump", "set_state", "set_flag", "add_evidence", "revise", "evaluated_by"}


class TransactionError(Exception):
    pass


def compact(value):
    return json.dumps(value, separators=(",", ":"), ensure_ascii=False)


def jq_default(value, fallback):
    """Implement jq's `//` default for null and false values."""
    return fallback if value is None or value is False else value


def issue_invariant_violated(index):
    issues = index.get("issues") if type(index) is dict else None
    if type(issues) is not list:
        return False
    return any(
        type(issue) is dict
        and (
            (issue.get("state") in ("accepted", "rejected") and issue.get("peer_reviewed") is not True)
            or (issue.get("fully_vetted") is True and issue.get("peer_reviewed") is not True)
        )
        for issue in issues
    )


def validate_issue(issue):
    return (
        type(issue) is dict
        and type(issue.get("id")) is str
        and panel_valid_id(issue["id"])
        and type(issue.get("claim")) is str
        and "location" in issue
        and valid_location(issue["location"])
        and type(issue.get("category")) is str
        and issue["category"] in CATEGORIES
        and type(issue.get("severity")) is str
        and issue["severity"] in SEVERITIES
        and type(issue.get("evidence_pro")) is list
        and bool(issue["evidence_pro"])
        and all(valid_point(point) for point in issue["evidence_pro"])
        and type(issue.get("evidence_contra")) is list
        and all(valid_point(point) for point in issue["evidence_contra"])
        and all(type(issue.get(flag)) is bool for flag in FLAGS)
        and issue.get("state") in ("open", "accepted", "rejected")
        and type(issue.get("rounds_debated")) in {int, float}
        and not isinstance(issue.get("rounds_debated"), bool)
        and issue["rounds_debated"] == 0
        and type(issue.get("card_rev")) in {int, float}
        and not isinstance(issue.get("card_rev"), bool)
        and issue["card_rev"] == 0
        and (not issue["fully_vetted"] or issue["peer_reviewed"])
        and (issue["state"] not in {"accepted", "rejected"} or issue["peer_reviewed"])
    )


def validate_payload(payload):
    if type(payload) is not dict or not set(payload).issubset(PAYLOAD_KEYS):
        return False
    if "add_issues" in payload and not (
        type(payload["add_issues"]) is list and all(validate_issue(issue) for issue in payload["add_issues"])
    ):
        return False
    if "bump" in payload and not (
        type(payload["bump"]) is list and all(type(issue_id) is str for issue_id in payload["bump"])
    ):
        return False
    if "set_state" in payload and not (
        type(payload["set_state"]) is list
        and all(
            type(change) is dict
            and type(change.get("id")) is str
            and type(change.get("state")) is str
            and change["state"] in STATES
            for change in payload["set_state"]
        )
    ):
        return False
    if "set_flag" in payload and not (
        type(payload["set_flag"]) is list
        and all(
            type(change) is dict
            and type(change.get("id")) is str
            and type(change.get("flag")) is str
            and change["flag"] in FLAGS
            and type(change.get("value")) is bool
            for change in payload["set_flag"]
        )
    ):
        return False
    if "add_evidence" in payload and not (
        type(payload["add_evidence"]) is list
        and all(
            type(change) is dict
            and type(change.get("id")) is str
            and type(change.get("side")) is str
            and change["side"] in {"pro", "contra"}
            and valid_point(change.get("point"))
            for change in payload["add_evidence"]
        )
    ):
        return False
    if "revise" in payload and not (
        type(payload["revise"]) is list and all(validate_revision(change) for change in payload["revise"])
    ):
        return False
    if "evaluated_by" in payload and not (
        type(payload["evaluated_by"]) is dict
        and all(
            type(issue_id) is str
            and type(seats) is list
            and all(type(seat) is str for seat in seats)
            and len(set(seats)) == len(seats)
            for issue_id, seats in payload["evaluated_by"].items()
        )
    ):
        return False
    return True


def validate_revision(change):
    if type(change) is not dict or type(change.get("id")) is not str or type(change.get("fields")) is not dict:
        return False
    fields = change["fields"]
    if not set(fields).issubset({"severity", "claim", "location", "category"}):
        return False
    return (
        ("claim" not in fields or type(fields["claim"]) is str)
        and ("location" not in fields or valid_location(fields["location"]))
        and ("category" not in fields or (type(fields["category"]) is str and fields["category"] in CATEGORIES))
        and ("severity" not in fields or (type(fields["severity"]) is str and fields["severity"] in SEVERITIES))
    )


def require_targets(index, payload):
    issues = index.get("issues", [])
    existing = {issue.get("id") for issue in issues if type(issue) is dict}
    added_ids = [issue["id"] for issue in payload.get("add_issues", [])]
    if any(issue_id in existing for issue_id in added_ids):
        raise TransactionError("add_issues contains already existing IDs")
    if len(set(added_ids)) != len(added_ids):
        raise TransactionError("add_issues contains duplicate IDs")
    state_ids = [change["id"] for change in payload.get("set_state", [])]
    if len(set(state_ids)) != len(state_ids):
        raise TransactionError("duplicate set_state for same ID")
    flag_pairs = [(change["id"], change["flag"]) for change in payload.get("set_flag", [])]
    if len(set(flag_pairs)) != len(flag_pairs):
        raise TransactionError("duplicate set_flag for same ID/flag")
    revise_ids = [change["id"] for change in payload.get("revise", [])]
    if len(set(revise_ids)) != len(revise_ids):
        raise TransactionError("duplicate revise for same ID")
    targets = list(payload.get("bump", []))
    targets += state_ids
    targets += [change["id"] for change in payload.get("set_flag", [])]
    targets += [change["id"] for change in payload.get("add_evidence", [])]
    targets += revise_ids
    targets += list(payload.get("evaluated_by", {}).keys())
    if any(target not in existing for target in targets):
        raise TransactionError("mutation target IDs do not exist or target a newly added issue")


def increment(issue, field):
    value = issue.get(field, 0)
    if value is None:
        # jq's += would fail here; ordinary persisted records always have counters.
        raise TransactionError("counter is not numeric")
    issue[field] = value + 1


def apply_sweep(index, payload, round_number, epoch):
    current_epoch = jq_default(index.get("run_epoch"), 0)
    if str(current_epoch) != epoch:
        raise TransactionError("stale sweep commit")
    committed = jq_default(index.get("committed_rounds"), [])
    if round_number in committed:
        return index, True
    if jq_default(index.get("round"), 0) + 1 != round_number:
        raise TransactionError("out of order commit")
    require_targets(index, payload)

    index["committed_rounds"] = committed + [round_number]
    index["round"] = round_number
    index["issues"] = index["issues"] + payload.get("add_issues", [])
    evaluated_by = jq_default(index.get("evaluated_by"), {})
    index["evaluated_by"] = {**evaluated_by, **payload.get("evaluated_by", {})}
    for issue_id in set(payload.get("bump", [])):
        for issue in index["issues"]:
            if issue.get("id") == issue_id:
                increment(issue, "rounds_debated")
                increment(issue, "card_rev")
    for change in payload.get("set_state", []):
        for issue in index["issues"]:
            if issue.get("id") == change["id"]:
                issue["state"] = change["state"]
                increment(issue, "card_rev")
    for change in payload.get("set_flag", []):
        for issue in index["issues"]:
            if issue.get("id") == change["id"]:
                issue[change["flag"]] = change["value"]
                increment(issue, "card_rev")
    for change in payload.get("add_evidence", []):
        for issue in index["issues"]:
            if issue.get("id") == change["id"]:
                key = "evidence_pro" if change["side"] == "pro" else "evidence_contra"
                issue[key] = issue[key] + [change["point"]]
                increment(issue, "card_rev")
    for change in payload.get("revise", []):
        for issue in index["issues"]:
            if issue.get("id") == change["id"]:
                issue.update(change["fields"])
                increment(issue, "card_rev")
    if issue_invariant_violated(index):
        raise TransactionError("terminal/fully_vetted states require peer_reviewed=true")
    return index, False


def read_index(path):
    with open(path, "r", encoding="utf-8") as handle:
        return json.load(handle)


def write_index(path, index):
    panel_atomic_write(path, compact(index) + "\n")


def mutation_failure():
    print("index: mutate failed (filter rejected or bad JSON); index.json left intact", file=sys.stderr)
    return 1


def main(argv):
    cmd = argv[1] if len(argv) > 1 else ""
    run_id = argv[2] if len(argv) > 2 else ""
    panel_require_id(run_id)
    path = f"/tmp/{run_id}/index.json"
    if not os.path.isfile(path):
        print(f"index: no index for {run_id}", file=sys.stderr)
        return 1

    if cmd == "get":
        with open(path, "rb") as handle:
            sys.stdout.buffer.write(handle.read())
        return 0
    if cmd == "issue":
        issue_id = argv[3] if len(argv) > 3 else ""
        index = read_index(path)
        for issue in index["issues"]:
            if issue.get("id") == issue_id:
                print(compact(issue))
        return 0
    if cmd == "gate-status":
        index = read_index(path)
        open_issues = [issue for issue in index["issues"] if issue.get("state") == "open"]
        print(compact({"open": len(open_issues), "low_only": bool(open_issues) and all(issue.get("severity") == "low" for issue in open_issues)}))
        return 0

    mutations = {"put", "bump", "state", "flag", "commit-sweep", "reopen"}
    if cmd not in mutations:
        print("usage: index {get|put|issue|bump|state|flag|gate-status|commit-sweep|reopen} <ID> ...", file=sys.stderr)
        return 2
    os.makedirs(f"/tmp/{run_id}", exist_ok=True)
    with open(f"/tmp/{run_id}/.index.lock", "a+b") as lock:
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)
        if cmd == "put":
            raw = sys.stdin.buffer.read()
            try:
                candidate = json.loads(raw)
            except (UnicodeDecodeError, json.JSONDecodeError):
                print("index put: invalid JSON or invariant violation", file=sys.stderr)
                return 1
            if issue_invariant_violated(candidate):
                print("index put: invalid JSON or invariant violation", file=sys.stderr)
                return 1
            panel_atomic_write(path, raw.rstrip(b"\n"))
            return 0

        if cmd == "state":
            state = argv[4] if len(argv) > 4 else ""
            if state not in STATES:
                print(f"index state: bad state {state} (allowed: open|accepted|rejected|contested|unresolved|merged)", file=sys.stderr)
                return 2
        if cmd == "flag":
            flag = argv[4] if len(argv) > 4 else ""
            boolean = argv[5] if len(argv) > 5 else ""
            if flag not in FLAGS:
                print(f"index flag: bad flag {flag}", file=sys.stderr)
                return 2
            if boolean not in {"true", "false"}:
                print("index flag: bool must be true|false", file=sys.stderr)
                return 2
        if cmd == "commit-sweep":
            round_text = argv[3] if len(argv) > 3 else ""
            epoch = argv[4] if len(argv) > 4 else ""
            if not round_text.isascii() or not round_text.isdecimal():
                print("index commit-sweep: round must be an integer", file=sys.stderr)
                return 2
            if not epoch.isascii() or not epoch.isdecimal():
                print("index commit-sweep: epoch must be an integer", file=sys.stderr)
                return 2
            raw = sys.stdin.buffer.read()
            if not raw:
                raw = b"{}"
            try:
                payload = json.loads(raw)
            except (UnicodeDecodeError, json.JSONDecodeError):
                print("index commit-sweep: payload must be a JSON object", file=sys.stderr)
                return 2
            if type(payload) is not dict:
                print("index commit-sweep: payload must be a JSON object", file=sys.stderr)
                return 2
            if not validate_payload(payload):
                print("index commit-sweep: invalid payload format", file=sys.stderr)
                return 2
        if cmd == "reopen":
            category = argv[3] if len(argv) > 3 else ""
            if category not in {"both", "unresolved", "contested"}:
                print("index reopen: category must be both|unresolved|contested", file=sys.stderr)
                return 2

        try:
            index = copy.deepcopy(read_index(path))
            if cmd == "bump":
                issue_id = argv[3] if len(argv) > 3 else ""
                for issue in index["issues"]:
                    if issue.get("id") == issue_id:
                        issue["rounds_debated"] = jq_default(issue.get("rounds_debated"), 0) + 1
                        issue["card_rev"] = jq_default(issue.get("card_rev"), 0) + 1
                if issue_invariant_violated(index):
                    raise TransactionError()
                write_index(path, index)
            elif cmd == "state":
                issue_id = argv[3] if len(argv) > 3 else ""
                for issue in index["issues"]:
                    if issue.get("id") == issue_id:
                        issue["state"] = state
                        issue["card_rev"] = jq_default(issue.get("card_rev"), 0) + 1
                if issue_invariant_violated(index):
                    raise TransactionError()
                write_index(path, index)
            elif cmd == "flag":
                issue_id = argv[3] if len(argv) > 3 else ""
                for issue in index["issues"]:
                    if issue.get("id") == issue_id:
                        issue[flag] = boolean == "true"
                        issue["card_rev"] = jq_default(issue.get("card_rev"), 0) + 1
                if issue_invariant_violated(index):
                    raise TransactionError()
                write_index(path, index)
            elif cmd == "commit-sweep":
                updated, idempotent = apply_sweep(index, payload, int(round_text), epoch)
                if not idempotent:
                    write_index(path, updated)
            else:
                def matches(issue):
                    return issue.get("state") in ("unresolved", "contested") if category == "both" else issue.get("state") == category

                if not any(matches(issue) for issue in index["issues"]):
                    print(f"index reopen: no {category} issue to re-open", file=sys.stderr)
                    return 3
                index["committed_rounds"] = []
                index["round"] = 0
                index["run_epoch"] = jq_default(index.get("run_epoch"), 0) + 1
                for issue in index["issues"]:
                    if matches(issue):
                        issue.update({"state": "open", "rounds_debated": 0, "peer_reviewed": False, "fully_vetted": False, "detail_contested": False})
                        issue["card_rev"] = jq_default(issue.get("card_rev"), 0) + 1
                if issue_invariant_violated(index):
                    raise TransactionError()
                write_index(path, index)
        except (KeyError, TypeError, ValueError, TransactionError, json.JSONDecodeError):
            return mutation_failure()
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
