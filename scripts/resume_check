#!/usr/bin/env bash
# resume_check — decide whether a prior run can be resumed/continued. Prints
# ONE verdict line. `panel-review:resume`/`panel-review:continue` adopt the
# run's scope from its OWN manifest (they take no scope argument), so the
# --scope this script is given is always that adopted value — comparing it is
# a cheap self-consistency check, not discrimination between requests. The
# real test is --diff-hash: a FRESHLY resolved hash of that same scope vs the
# manifest's stored one, which is what catches "the code under review changed
# since this snapshot."
#
# Usage:
#   resume_check --workdir DIR --scope STR --diff-hash HEX
#
# Output (stdout), exactly one of:
#   fresh                  no marker dir -> nothing to resume/continue
#   resume <ID>            run still has open issues -> can resume
#   continuable <ID>       finished run (no open issues) with unresolved/contested left -> continue
#   stale <ID>             marker but /tmp/<ID> missing/empty -> drop & start fresh
#   diverged <ID>          the diff hash no longer matches — the code under review
#                          changed since the snapshot; can't resume or continue
#   ambiguous              more than one marker dir -> needs manual cleanup
#
# Unlike `inspect_run` (status's pure/read-only inspector), this script MAY
# repair a corrupt index.json from its .bak sibling — the action commands are
# already mutating the run, so a same-session repair is safe here but would be
# a hidden write status (a read-only report) must never perform.
#
# Limits and instructions are NOT part of the resume identity: limits are
# explicitly overridable (set_limits), and instructions are shown/adopted, not
# matched — so neither is compared here.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"; . "$here/_panel_common.sh"

workdir="" scope="" dh=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --workdir) workdir="$2"; shift 2;;
    --scope) scope="$2"; shift 2;;
    --diff-hash) dh="$2"; shift 2;;
    *) echo "resume_check: unknown arg: $1" >&2; exit 2;;
  esac
done
[ -n "$workdir" ] || { echo "resume_check: need --workdir" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "resume_check: jq not found" >&2; exit 127; }

base="$workdir/.panel-review"
[ -d "$base" ] || { echo "fresh"; exit 0; }

# Collect our marker dirs (each named for its <ID>, with our marker file).
ids=(); for d in "$base"/*/; do [ -f "$d/.panel-run" ] || continue; ids+=("$(basename "$d")"); done
[ "${#ids[@]}" -eq 0 ] && { echo "fresh"; exit 0; }
[ "${#ids[@]}" -gt 1 ] && { echo "ambiguous"; exit 0; }

id="${ids[0]}"
panel_valid_id "$id" || { echo "ambiguous"; exit 0; }   # unexpected name -> hands off to human

man="/tmp/$id/manifest.json"
if [ ! -s "/tmp/$id/index.json" ] || [ ! -s "$man" ]; then echo "stale $id"; exit 0; fi

if ! jq -e . "/tmp/$id/index.json" >/dev/null 2>&1; then
  if [ -s "/tmp/$id/index.json.bak" ] && jq -e . "/tmp/$id/index.json.bak" >/dev/null 2>&1; then
    panel_atomic_write "/tmp/$id/index.json" < "/tmp/$id/index.json.bak"
  else
    echo "stale $id"; exit 0
  fi
fi

# A corrupt/partially-written manifest must NOT crash the check (set -e) — that
# would block the caller. Degrade to "stale" so it can cleanly start fresh.
if ! m_scope=$(jq -r '.scope' "$man" 2>/dev/null) \
   || ! m_dh=$(jq -r '.diff_hash' "$man" 2>/dev/null); then
  echo "stale $id"; exit 0
fi

if [ "$m_scope" = "$scope" ] && [ "$m_dh" = "$dh" ]; then
  # A FINISHED run has no open issues; if it also handed back unresolved/contested
  # issues it is continuable. An interrupted run still has open issues -> plain resume.
  # On any jq error, default to resume (open_n=1) — never mislabel as continuable.
  open_n="$(jq '[.issues[] | select(.state=="open")] | length' "/tmp/$id/index.json" 2>/dev/null || echo 1)"
  left_n="$(jq '[.issues[] | select(.state=="unresolved" or .state=="contested")] | length' "/tmp/$id/index.json" 2>/dev/null || echo 0)"
  if [ "$open_n" = "0" ] && [ "$left_n" != "0" ]; then
    echo "continuable $id"
  else
    echo "resume $id"
  fi
else
  echo "diverged $id"
fi
