#!/usr/bin/env bash
# sweep — checkpointed debate sweeps, so a crash mid-sweep never double-counts.
# A sweep = one full pass over the open issues across all engaged seats. Per-seat
# outputs are cached as they land; a sweep is "committed" only when complete, and
# ONLY a committed sweep increments rounds_debated. On resume, cached outputs let
# the referee rerun just the missing seats.
#
# Subcommands:
#   sweep begin  <ID> <round> <epoch>             create the sweep dir
#   sweep record <ID> <round> <epoch> <seat> <file> [batch] cache one seat/batch's raw output
#   sweep has    <ID> <round> <seat> [batch]        exit 0 if that seat/batch already recorded
#   sweep commit <ID> <round> <epoch>             commit the sweep; bump issue ids on stdin (one per line)
#   sweep done   <ID> <round>                 exit 0 if the sweep is committed
#
# Idempotency: the durable record of "this round was counted" lives in the index
# (.committed_rounds), not in the marker file. `commit` delegates the bump to
# `index commit-sweep`, which is a no-op if the round is already committed — so a
# crash mid-commit, then a resume + re-commit, never double-counts. `done`
# queries that same committed_rounds, so it is the single source of truth.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"; . "$here/_panel_common.sh"

cmd="${1-}"; id="${2-}"; panel_require_id "$id"
round="${3-}"
case "$round" in ''|*[!0-9]*) echo "sweep: round must be a number" >&2; exit 2;; esac
sd="/tmp/$id/sweeps/round-$round"

idx="/tmp/$id/index.json"

case "$cmd" in
  begin)
          epoch="${4-}"
          case "$epoch" in ''|*[!0-9]*) echo "sweep begin: requires numeric epoch" >&2; exit 2;; esac
          curr_epoch="$(jq -r '.run_epoch // 0' "$idx")"
          if [ "$curr_epoch" != "$epoch" ]; then echo "sweep begin: stale run epoch $epoch != $curr_epoch" >&2; exit 1; fi
          if [ -d "$sd" ]; then
            if [ -s "$sd/.epoch" ]; then
              dir_epoch="$(cat "$sd/.epoch")"
              if [ "$epoch" != "$dir_epoch" ]; then rm -rf -- "$sd"; fi
            else
              rm -rf -- "$sd"
            fi
          fi
          mkdir -p "$sd" 
          if ! [ -s "$sd/.epoch" ]; then
            echo "$epoch" | panel_atomic_write "$sd/.epoch"
          fi
          ;;
  record) epoch="${4-}"; seat="${5-}"; src="${6-}"; batch="${7-all}"
	          case "$epoch" in ''|*[!0-9]*) echo "sweep record: requires numeric epoch" >&2; exit 2;; esac
	          case "$seat" in ''|*[!A-Za-z0-9._-]*) echo "sweep: bad seat name" >&2; exit 2;; esac
	          case "$batch" in ''|*[!A-Za-z0-9._-]*) echo "sweep: bad batch name" >&2; exit 2;; esac
	          [ -f "$src" ] || { echo "sweep record: no such file: $src" >&2; exit 1; }
	          [ -d "$sd" ] || { echo "sweep record: sweep dir not found" >&2; exit 1; }
	          [ -s "$sd/.epoch" ] || { echo "sweep record: sweep epoch not found or empty" >&2; exit 1; }
	          curr_epoch="$(jq -r '.run_epoch // 0' "$idx")"
	          dir_epoch="$(cat "$sd/.epoch")"
	          case "$dir_epoch" in ''|*[!0-9]*) echo "sweep record: sweep epoch not numeric" >&2; exit 1;; esac
	          if [ "$epoch" != "$dir_epoch" ]; then echo "sweep record: stale worker epoch $epoch != $dir_epoch" >&2; exit 1; fi
	          if [ "$curr_epoch" != "$dir_epoch" ]; then echo "sweep record: stale run epoch" >&2; exit 1; fi
	          # Atomic temp+sync+rename (via panel_atomic_write) so an interrupted copy
	          # never leaves a truncated $seat.$batch.out that `has` would accept.
	          panel_atomic_write "$sd/$seat.$batch.out" < "$src" ;;
  has)    seat="$4"; batch="${5-all}"
	          case "$batch" in ''|*[!A-Za-z0-9._-]*) echo "sweep: bad batch name" >&2; exit 2;; esac
	          [ -f "$sd/$seat.$batch.out" ] ;;
  done)   [ -f "$idx" ] && jq -e --argjson r "$round" '((.committed_rounds // []) | any(. == $r))' "$idx" >/dev/null 2>&1 ;;
  commit) epoch="${4-}"
          case "$epoch" in ''|*[!0-9]*) echo "sweep commit: requires numeric epoch" >&2; exit 2;; esac
          [ -d "$sd" ] || { echo "sweep commit: no sweep $round for $id" >&2; exit 1; }
          # The round's full decision payload (states, flags, evidence, new issues,
          # and the `bump` id list — see `index commit-sweep`) arrives on stdin.
          # Apply it as ONE atomic, idempotent step so a crash never leaves a
          # half-applied round, then drop the audit marker (committed_rounds in the
          # index is the real source of truth, this file is just for inspection).
          [ -s "$sd/.epoch" ] || { echo "sweep commit: no epoch found or empty" >&2; exit 1; }
          dir_epoch="$(cat "$sd/.epoch")"
          case "$dir_epoch" in ''|*[!0-9]*) echo "sweep commit: sweep epoch not numeric" >&2; exit 1;; esac
          if [ "$epoch" != "$dir_epoch" ]; then echo "sweep commit: stale worker epoch $epoch != $dir_epoch" >&2; exit 1; fi
          curr_epoch="$(jq -r '.run_epoch // 0' "$idx")"
          if [ "$curr_epoch" != "$dir_epoch" ]; then echo "sweep commit: stale run epoch" >&2; exit 1; fi
          cat | "$here/index" commit-sweep "$id" "$round" "$epoch"
          date -Is | panel_atomic_write "$sd/sweep_complete" ;;
  *) echo "usage: sweep {begin|record|has|done|commit} <ID> <round> ..." >&2; exit 2 ;;
esac
