#!/usr/bin/env python3
"""Checkpointed debate-sweep state management."""

import datetime
import glob
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)

from panel_common import panel_atomic_write, panel_require_id
from seat_contract import PHASES


NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")
NUMBER_RE = re.compile(r"^[0-9]+$")
USAGE = "usage: sweep {begin|record|plan|plan-scaffold|extend-plan|ingest-batch|drop-seat|resume-plan|has|done|commit} <ID> <round> ..."
STANCE_TAG, NEW_FINDINGS_TAG = PHASES["debate"]["required_blocks"]


def fail(message, code):
    print(message, file=sys.stderr)
    return code


def compact(value):
    return json.dumps(value, separators=(",", ":"), ensure_ascii=False)


def is_number(value):
    return bool(NUMBER_RE.fullmatch(value))


def valid_name(value):
    return bool(NAME_RE.fullmatch(value))


def read_index(path):
    with open(path, encoding="utf-8") as handle:
        return json.load(handle)


def jq_raw(value):
    if value is None:
        return "0"
    if type(value) is str:
        return value
    return compact(value)


def index_epoch(path):
    return jq_raw(read_index(path).get("run_epoch", 0))


def read_epoch(path):
    with open(path, encoding="utf-8") as handle:
        return handle.read().strip()


def epoch_file_present(path):
    return os.path.isfile(path) and os.path.getsize(path) > 0


def sorted_ids(values):
    return sorted(values, key=lambda value: value.encode("utf-8"))


def _sorted_open_issue_ids(index):
    return sorted_ids([
        issue.get("id") for issue in index.get("issues", [])
        if type(issue) is dict and issue.get("state") == "open" and type(issue.get("id")) is str
    ])


def write_atomic(path, data):
    panel_atomic_write(path, data)


def batch_paths(sd, run_dir, round_text, seat, batch):
    prefix = os.path.join(sd, f"{seat}.{batch}")
    return {
        "out": f"{prefix}.out",
        "stances": f"{prefix}.stances.json",
        "expected": f"{prefix}.expected.ids",
        "source": f"{prefix}.source.json",
        "new_findings": os.path.join(run_dir, f"nf.{round_text}.{seat}.{batch}.json"),
        "new_findings_status": os.path.join(run_dir, f"status.nf.{round_text}.{seat}.{batch}"),
    }


def read_status(path):
    try:
        with open(path, encoding="utf-8") as handle:
            return int(handle.read().strip())
    except (OSError, ValueError):
        return None


def batch_complete(paths):
    return (
        all(os.path.isfile(paths[name]) for name in ("out", "stances", "expected", "source", "new_findings"))
        and read_status(paths["new_findings_status"]) == 0
    )


def batch_corrupt(paths):
    return os.path.isfile(paths["out"]) and not batch_complete(paths)


def clear_batch_checkpoint(paths):
    for name in ("out", "stances", "expected", "source", "new_findings"):
        try:
            os.unlink(paths[name])
        except FileNotFoundError:
            pass


def validate_plan(plan):
    if type(plan) is not dict:
        return False, "plan must be an object"
    for key in plan:
        if key != "batches":
            return False, f"plan: unknown key {key!r}"
    if type(plan.get("batches")) is not list or not plan["batches"]:
        return False, "plan: top-level 'batches' must be a non-empty list"
    pairs = set()
    for batch_number, batch in enumerate(plan["batches"]):
        if type(batch) is not dict:
            return False, f"batch[{batch_number}] must be an object"
        for key in batch:
            if key not in {"seat", "batch", "expected_ids"}:
                hint = " (did you mean 'expected_ids'?)" if key == "ids" else ""
                return False, f"batch[{batch_number}]: unknown key {key!r}{hint}"
        seat = batch.get("seat")
        name = batch.get("batch")
        expected = batch.get("expected_ids")
        if type(seat) is not str:
            return False, f"batch[{batch_number}].seat must be a string"
        if type(name) is not str:
            return False, f"batch[{batch_number}].batch must be a string, got {type(name).__name__}"
        if type(expected) is not list or not expected:
            return False, f"batch[{batch_number}].expected_ids must be a non-empty list"
        for issue_number, issue_id in enumerate(expected):
            if type(issue_id) is not str or not issue_id:
                return False, f"batch[{batch_number}].expected_ids[{issue_number}] must be a non-empty string"
        if len(set(expected)) != len(expected):
            return False, f"batch[{batch_number}].expected_ids contains duplicates"
        pair = (seat, name)
        if pair in pairs:
            return False, f"duplicate (seat,batch) pair: ({seat},{name})"
        pairs.add(pair)
    return True, ""


def expected_ids(path):
    with open(path, "rb") as handle:
        raw = handle.read()
    lines = raw.decode("utf-8").split("\n")
    if raw.endswith(b"\n"):
        lines.pop()
    unique = sorted_ids(set(lines))
    if not unique or any(not line for line in lines) or len(lines) != len(unique):
        return None
    return unique


def parsed_ids(path):
    with open(path, "rb") as handle:
        raw = handle.read()
    parsed_lines = raw.decode("utf-8").split("\n")
    if raw.endswith(b"\n"):
        parsed_lines.pop()
    received_output = "".join(f"{json.loads(line)['id']}\n" for line in parsed_lines)
    return parsed_lines, sorted_ids(received_output.split("\n")[:-1])


def cmd_begin(sd, idx, epoch):
    if not is_number(epoch):
        return fail("sweep begin: requires numeric epoch", 2)
    current = index_epoch(idx)
    if current != epoch:
        return fail(f"sweep begin: stale run epoch {epoch} != {current}", 1)
    epoch_path = os.path.join(sd, ".epoch")
    if os.path.isdir(sd):
        if not epoch_file_present(epoch_path) or read_epoch(epoch_path) != epoch:
            shutil.rmtree(sd)
    os.makedirs(sd, exist_ok=True)
    if not epoch_file_present(epoch_path):
        write_atomic(epoch_path, f"{epoch}\n")
    return 0


def cmd_record(sd, idx, epoch, seat, src, batch):
    if not is_number(epoch):
        return fail("sweep record: requires numeric epoch", 2)
    if not valid_name(seat):
        return fail("sweep: bad seat name", 2)
    if not valid_name(batch):
        return fail("sweep: bad batch name", 2)
    if not os.path.isfile(src):
        return fail(f"sweep record: no such file: {src}", 1)
    if not os.path.isdir(sd):
        return fail("sweep record: sweep dir not found", 1)
    epoch_path = os.path.join(sd, ".epoch")
    if not epoch_file_present(epoch_path):
        return fail("sweep record: sweep epoch not found or empty", 1)
    directory_epoch = read_epoch(epoch_path)
    if not is_number(directory_epoch):
        return fail("sweep record: sweep epoch not numeric", 1)
    if epoch != directory_epoch:
        return fail(f"sweep record: stale worker epoch {epoch} != {directory_epoch}", 1)
    if index_epoch(idx) != directory_epoch:
        return fail("sweep record: stale run epoch", 1)
    with open(src, "rb") as handle:
        write_atomic(os.path.join(sd, f"{seat}.{batch}.out"), handle.read())
    return 0


def cmd_plan(sd, epoch, plan_path):
    if not is_number(epoch):
        return fail("sweep plan: requires numeric epoch", 2)
    if not os.path.isfile(plan_path):
        return fail(f"sweep plan: no such file: {plan_path}", 1)
    epoch_path = os.path.join(sd, ".epoch")
    if not os.path.isdir(sd) or not epoch_file_present(epoch_path):
        return fail("sweep plan: sweep dir not found", 1)
    if read_epoch(epoch_path) != epoch:
        return fail("sweep plan: stale worker epoch", 1)
    try:
        with open(plan_path, encoding="utf-8") as handle:
            plan = json.load(handle)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return fail("sweep plan: plan file is unreadable or not valid JSON", 2)
    valid, reason = validate_plan(plan)
    if not valid:
        return fail(f"sweep plan: {reason}", 2)
    stored_path = os.path.join(sd, "plan.json")
    if os.path.isfile(stored_path):
        try:
            with open(stored_path, encoding="utf-8") as handle:
                stored = json.load(handle)
        except (OSError, UnicodeDecodeError, json.JSONDecodeError):
            return fail("sweep plan: existing plan differs", 1)
        if type(stored.get("epoch")) is not int or stored["epoch"] != int(epoch) or stored.get("batches") != plan["batches"]:
            return fail("sweep plan: existing plan differs", 1)
    else:
        stored = dict(plan)
        stored["epoch"] = int(epoch)
        stored["dropped_seats"] = []
        write_atomic(stored_path, compact(stored) + "\n")
    return 0


def cmd_plan_scaffold(idx, seats):
    if not seats:
        return fail("sweep plan-scaffold: requires at least one seat", 2)
    seen = set()
    for seat in seats:
        if not valid_name(seat):
            return fail(f"sweep plan-scaffold: bad seat name: {seat}", 2)
        if seat in seen:
            return fail(f"sweep plan-scaffold: duplicate seat: {seat}", 2)
        seen.add(seat)
    try:
        index = read_index(idx)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return fail("sweep plan-scaffold: index not found or invalid", 1)
    issue_ids = _sorted_open_issue_ids(index)
    if not issue_ids:
        return fail("sweep plan-scaffold: no open issues", 1)
    plan = {"batches": [
        {"seat": seat, "batch": "1", "expected_ids": issue_ids}
        for seat in seats
    ]}
    print(compact(plan))
    return 0


def cmd_extend_plan(sd, idx, epoch, seats):
    if not is_number(epoch):
        return fail("sweep extend-plan: requires numeric epoch", 2)
    if not seats:
        return fail("sweep extend-plan: requires at least one seat", 2)
    if len(seats) != len(set(seats)) or any(not valid_name(seat) for seat in seats):
        return fail("sweep extend-plan: seats must be distinct safe names", 2)
    epoch_path = os.path.join(sd, ".epoch")
    plan_path = os.path.join(sd, "plan.json")
    if not epoch_file_present(epoch_path) or not os.path.isfile(plan_path):
        return fail("sweep extend-plan: stored plan not found", 1)
    if read_epoch(epoch_path) != epoch or index_epoch(idx) != epoch:
        return fail("sweep extend-plan: stale run epoch", 1)
    try:
        with open(plan_path, encoding="utf-8") as handle:
            plan = json.load(handle)
        index = read_index(idx)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return fail("sweep extend-plan: plan or index is invalid", 1)
    valid, reason = validate_plan({"batches": plan.get("batches")})
    if not valid or plan.get("epoch") != int(epoch) or type(plan.get("dropped_seats")) is not list:
        return fail(f"sweep extend-plan: invalid stored plan: {reason or 'metadata'}", 1)
    issue_ids = _sorted_open_issue_ids(index)
    if not issue_ids:
        return fail("sweep extend-plan: no open issues", 1)
    if any(entry["batch"] != "1" or sorted_ids(entry["expected_ids"]) != issue_ids for entry in plan["batches"]):
        return fail("sweep extend-plan: only a matching common single-batch plan can be extended", 1)
    plan["dropped_seats"] = sorted(set(plan["dropped_seats"]) - set(seats))
    planned = {entry["seat"] for entry in plan["batches"]}
    for seat in seats:
        if seat not in planned:
            plan["batches"].append({"seat": seat, "batch": "1", "expected_ids": issue_ids})
    write_atomic(plan_path, compact(plan) + "\n")
    return 0


def cmd_ingest_batch(sd, run_dir, round_text, epoch, seat, batch, expected_path, raw_path):
    if not is_number(epoch):
        return fail("sweep ingest-batch: requires numeric epoch", 2)
    if not valid_name(seat):
        return fail("sweep ingest-batch: bad seat name", 2)
    if not valid_name(batch):
        return fail("sweep ingest-batch: bad batch name", 2)
    epoch_path = os.path.join(sd, ".epoch")
    if not os.path.isdir(sd) or not epoch_file_present(epoch_path):
        return fail("sweep ingest-batch: sweep dir not found", 1)
    if read_epoch(epoch_path) != epoch:
        return fail("sweep ingest-batch: stale worker epoch", 1)
    if not os.path.isfile(expected_path):
        return fail("sweep ingest-batch: no expected IDs file", 1)
    plan_path = os.path.join(sd, "plan.json")
    if not os.path.isfile(plan_path):
        return fail("sweep ingest-batch: no batch plan", 1)
    with open(plan_path, encoding="utf-8") as handle:
        plan = json.load(handle)
    if seat in plan.get("dropped_seats", []):
        return fail("sweep ingest-batch: seat was dropped", 1)
    wanted = expected_ids(expected_path)
    if wanted is None:
        return fail("sweep ingest-batch: expected IDs must be unique, non-empty lines", 2)
    planned = []
    for entry in plan.get("batches", []):
        if entry.get("seat") == seat and entry.get("batch") == batch:
            planned.extend(entry.get("expected_ids", []))
    if wanted != sorted_ids(planned):
        return fail("sweep ingest-batch: expected IDs do not match the batch plan", 2)

    paths = batch_paths(sd, run_dir, round_text, seat, batch)
    if batch_complete(paths):
        print('{"status":"complete"}')
        return 0
    clear_batch_checkpoint(paths)
    if not os.path.isfile(raw_path):
        write_atomic(paths["new_findings_status"], "4\n")
        print('{"status":"missing"}')
        return 0

    parsed = tempfile.NamedTemporaryFile(prefix=".stances.", dir=sd, delete=False)
    new_findings = tempfile.NamedTemporaryFile(prefix=".new-findings.", dir=sd, delete=False)
    try:
        with parsed:
            stance_result = subprocess.run(
                [os.path.join(HERE, "parse_block"), STANCE_TAG, raw_path, seat], stdout=parsed
            )
        with new_findings:
            new_findings_result = subprocess.run(
                [os.path.join(HERE, "parse_block"), NEW_FINDINGS_TAG, raw_path, seat],
                stdout=new_findings,
            )
        write_atomic(paths["new_findings_status"], f"{new_findings_result.returncode}\n")

        if stance_result.returncode == 4:
            print('{"status":"missing"}')
            return 0
        if os.path.getsize(parsed.name) == 0:
            print('{"status":"malformed"}' if stance_result.returncode == 5 else '{"status":"empty"}')
            return 0
        lines, received = parsed_ids(parsed.name)
        if received == wanted and len(lines) == len(wanted):
            if new_findings_result.returncode != 0:
                status = (
                    "missing_new_findings"
                    if new_findings_result.returncode in {1, 4}
                    else "malformed_new_findings"
                )
                print(compact({"status": status}))
                return 0
            response_result = subprocess.run(
                [os.path.join(HERE, "parse_block"), "--response", "debate", STANCE_TAG, raw_path],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            if response_result.returncode != 0:
                print('{"status":"malformed_response"}')
                return 0
            with open(new_findings.name, "rb") as handle:
                write_atomic(paths["new_findings"], handle.read())
            with open(parsed.name, "rb") as handle:
                write_atomic(paths["stances"], handle.read())
            write_atomic(paths["expected"], "".join(f"{value}\n" for value in wanted))
            write_atomic(
                paths["source"],
                compact(
                    {
                        "raw": os.path.abspath(raw_path),
                        "salvaged": os.path.abspath(raw_path)
                        == os.path.join(
                            run_dir,
                            "raw",
                            f"round{round_text}.{seat}.{batch}.txt.salvaged",
                        ),
                    }
                )
                + "\n",
            )
            with open(raw_path, "rb") as handle:
                # .out is the completion marker and is installed only after the whole
                # two-block checkpoint is durable.
                write_atomic(paths["out"], handle.read())
            print('{"status":"complete"}')
            return 0
        unique_received = sorted_ids(set(received))
        if len(received) != len(unique_received) or any(value not in wanted for value in received) or len(received) > len(wanted):
            status = "wrong_ids"
        else:
            status = "partial"
        print(compact({"status": status}))
        return 0
    finally:
        try:
            os.unlink(parsed.name)
        except OSError:
            pass
        try:
            os.unlink(new_findings.name)
        except OSError:
            pass


def cmd_drop_seat(sd, run_dir, round_text, seat):
    if not valid_name(seat):
        return fail("sweep drop-seat: bad seat name", 2)
    if not os.path.isdir(sd):
        return fail("sweep drop-seat: sweep dir not found", 1)
    for suffix in (".out", ".stances.json", ".expected.ids", ".source.json"):
        for path in glob.glob(os.path.join(sd, f"{seat}.*{suffix}")):
            try:
                os.unlink(path)
            except OSError:
                pass
    for path in glob.glob(os.path.join(run_dir, f"nf.{round_text}.{seat}.*.json")) + glob.glob(
        os.path.join(run_dir, f"status.nf.{round_text}.{seat}.*")
    ):
        try:
            os.unlink(path)
        except OSError:
            pass
    plan_path = os.path.join(sd, "plan.json")
    if os.path.isfile(plan_path):
        with open(plan_path, encoding="utf-8") as handle:
            plan = json.load(handle)
        plan["dropped_seats"] = sorted(set(plan.get("dropped_seats", [])) | {seat})
        write_atomic(plan_path, compact(plan) + "\n")
    return 0


def cmd_resume_plan(run_id, idx):
    index = read_index(idx)
    next_round = (index.get("round", 0) if index.get("round") is not None else 0) + 1
    sd = os.path.join("/tmp", run_id, "sweeps", f"round-{next_round}")
    if not os.path.isdir(sd):
        print(compact({"round": next_round, "status": "no_sweep", "batches": []}))
        return 0
    epoch_path = os.path.join(sd, ".epoch")
    if not epoch_file_present(epoch_path):
        return fail("sweep resume-plan: missing sweep epoch", 1)
    epoch = read_epoch(epoch_path)
    if epoch != jq_raw(index.get("run_epoch", 0)):
        return fail("sweep resume-plan: stale sweep epoch", 1)
    plan_path = os.path.join(sd, "plan.json")
    if not os.path.isfile(plan_path):
        print(compact({"round": next_round, "epoch": int(epoch), "status": "no_plan", "batches": []}))
        return 0
    with open(plan_path, encoding="utf-8") as handle:
        plan = json.load(handle)
    dropped = plan.get("dropped_seats", [])
    run_dir = os.path.join("/tmp", run_id)
    batches = []
    for entry in plan["batches"]:
        paths = batch_paths(sd, run_dir, str(next_round), entry["seat"], entry["batch"])
        if entry["seat"] in dropped:
            status = "dropped"
        elif batch_corrupt(paths):
            return fail(
                f"sweep resume-plan: corrupt complete checkpoint for {entry['seat']}/{entry['batch']}",
                1,
            )
        elif batch_complete(paths):
            status = "complete"
        else:
            status = "missing"
        batches.append({"seat": entry["seat"], "batch": entry["batch"], "status": status})
    print(compact({"round": next_round, "epoch": int(epoch), "batches": batches}))
    return 0


def cmd_commit(sd, idx, run_id, round_text, epoch):
    if not is_number(epoch):
        return fail("sweep commit: requires numeric epoch", 2)
    if not os.path.isdir(sd):
        return fail(f"sweep commit: no sweep {round_text} for {run_id}", 1)
    epoch_path = os.path.join(sd, ".epoch")
    if not epoch_file_present(epoch_path):
        return fail("sweep commit: no epoch found or empty", 1)
    directory_epoch = read_epoch(epoch_path)
    if not is_number(directory_epoch):
        return fail("sweep commit: sweep epoch not numeric", 1)
    if epoch != directory_epoch:
        return fail(f"sweep commit: stale worker epoch {epoch} != {directory_epoch}", 1)
    if index_epoch(idx) != directory_epoch:
        return fail("sweep commit: stale run epoch", 1)
    result = subprocess.run(
        [os.path.join(HERE, "index"), "commit-sweep", run_id, round_text, epoch],
        stdin=sys.stdin.buffer,
    )
    if result.returncode:
        return result.returncode
    write_atomic(os.path.join(sd, "sweep_complete"), datetime.datetime.now().astimezone().isoformat() + "\n")
    return 0


KNOWN_CMDS = {"begin", "record", "plan", "plan-scaffold", "extend-plan", "ingest-batch", "drop-seat",
              "resume-plan", "has", "done", "commit"}


def main(argv):
    cmd = argv[1] if len(argv) > 1 else ""
    # USAGE must be reachable WITHOUT a valid ID. panel_require_id("") aborts with
    # "invalid run id: ''", so if it ran first, `sweep`, `sweep -h`, or any unknown
    # verb could never print the interface — the referee's only recourse was to grep
    # the source (issues-2026-07-04 #1). Dispatch help/unknown BEFORE requiring an ID.
    if cmd in {"-h", "--help", "help"}:
        print(USAGE)
        return 0
    if cmd not in KNOWN_CMDS:
        return fail(USAGE, 2)
    run_id = argv[2] if len(argv) > 2 else ""
    panel_require_id(run_id)
    round_text = argv[3] if len(argv) > 3 else ""
    if cmd != "resume-plan" and not is_number(round_text):
        return fail("sweep: round must be a number", 2)
    sd = os.path.join("/tmp", run_id, "sweeps", f"round-{round_text}")
    run_dir = os.path.join("/tmp", run_id)
    idx = os.path.join("/tmp", run_id, "index.json")

    if cmd == "begin":
        return cmd_begin(sd, idx, argv[4] if len(argv) > 4 else "")
    if cmd == "record":
        return cmd_record(sd, idx, argv[4] if len(argv) > 4 else "", argv[5] if len(argv) > 5 else "", argv[6] if len(argv) > 6 else "", argv[7] if len(argv) > 7 else "all")
    if cmd == "plan":
        return cmd_plan(sd, argv[4] if len(argv) > 4 else "", argv[5] if len(argv) > 5 else "")
    if cmd == "plan-scaffold":
        return cmd_plan_scaffold(idx, argv[4:])
    if cmd == "extend-plan":
        return cmd_extend_plan(sd, idx, argv[4] if len(argv) > 4 else "", argv[5:])
    if cmd == "ingest-batch":
        return cmd_ingest_batch(sd, run_dir, round_text, argv[4] if len(argv) > 4 else "", argv[5] if len(argv) > 5 else "", argv[6] if len(argv) > 6 else "", argv[7] if len(argv) > 7 else "", argv[8] if len(argv) > 8 else "")
    if cmd == "drop-seat":
        return cmd_drop_seat(sd, run_dir, round_text, argv[4] if len(argv) > 4 else "")
    if cmd == "resume-plan":
        return cmd_resume_plan(run_id, idx)
    if cmd == "has":
        seat = argv[4] if len(argv) > 4 else ""
        batch = argv[5] if len(argv) > 5 else "all"
        if not valid_name(batch):
            return fail("sweep: bad batch name", 2)
        paths = batch_paths(sd, run_dir, round_text, seat, batch)
        if batch_corrupt(paths):
            return fail(f"sweep has: corrupt complete checkpoint for {seat}/{batch}", 2)
        return 0 if batch_complete(paths) else 1
    if cmd == "done":
        if not os.path.isfile(idx):
            return 1
        return 0 if any(
            type(value) in {int, float} and value == int(round_text)
            for value in read_index(idx).get("committed_rounds", [])
        ) else 1
    if cmd == "commit":
        return cmd_commit(sd, idx, run_id, round_text, argv[4] if len(argv) > 4 else "")
    return fail(USAGE, 2)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
