#!/usr/bin/env python3
"""Emit one marked phase from the canonical referee procedure."""

from pathlib import Path
import re
import sys


PHASES = ("common", "salvage", "round0", "debate", "degraded", "gate", "recovery", "verdict")
USAGE = f"usage: read_protocol_phase <{'|'.join(PHASES)}>"
SOURCE = Path(__file__).resolve().parents[1] / "skills" / "panel-review-for-agent" / "references" / "protocol.md"


def main(argv):
    if len(argv) == 2 and argv[1] in {"-h", "--help", "help"}:
        print(USAGE)
        return 0
    if len(argv) != 2 or argv[1] not in PHASES:
        print(USAGE, file=sys.stderr)
        return 2
    phase = argv[1]
    text = SOURCE.read_text(encoding="utf-8")
    pattern = rf"<!-- phase:{re.escape(phase)} -->\n(.*?)<!-- /phase:{re.escape(phase)} -->"
    matches = re.findall(pattern, text, re.DOTALL)
    if not matches:
        print(f"read_protocol_phase: canonical procedure has no complete {phase} phase", file=sys.stderr)
        return 1
    sys.stdout.write("\n".join(matches))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
