#!/usr/bin/env bash
# run_agy — the ONLY approved way to call the agy CLI for the Gemini seat.
#
# Usage:
#   run_agy "<prompt>"        # prompt as $1
#   run_agy < promptfile      # prompt on stdin (no args)
# Output: final assistant response on stdout. Nonzero exit = failed (caller
#         degrades, running with the remaining seats). agy's own stderr is forwarded.
#
# WHY this wrapper exists / the non-obvious agy contract:
#  - PROMPT VIA STDIN, NO `--print` FLAG. agy's `--print` is NOT a boolean — it
#    TAKES THE PROMPT AS ITS ARGUMENT (`--print "<prompt>"`; `--prompt` is an
#    alias). A bare `--print` with the prompt on stdin makes `--print` swallow the
#    NEXT token (`--model`) and desyncs the whole parse: --model AND --print-timeout
#    are silently dropped, so agy runs the ~/.gemini/.../settings.json default model
#    (Gemini 3.1 Pro) at the 5m DEFAULT print cap. Symptom seen in the field: every
#    attempt logged model="" and died at ~1497 polls (~5m), and the Pro->Flash
#    "fallback" was really two Pro runs. Fix: feed the prompt on stdin (a non-TTY
#    pipe that hits EOF) with NO `--print`; agy then reads stdin non-interactively
#    and the flags below actually bind. Confirmed in agy's own CLI logs: this form
#    logs model="Gemini 3.5 Flash (High)" and honors --print-timeout to the second.
#  - --print-timeout=15m, =FORM. agy's default is 5m0s, which guillotines a heavy
#    review mid-investigation. 15m is enough for a thorough Pro/Flash pass; the
#    outer `timeout WALL_TIMEOUT` is the hard backstop if agy ever truly hangs.
#  - --dangerously-skip-permissions: REQUIRED so the seat can actually RUN its tools
#    non-interactively — tilth (native MCP), grep/read, and the scratch-script writes
#    the review prompt asks for. It auto-approves those tool calls; agy is already a
#    full agentic tool user, so this does not newly "unsandbox" it. Repo integrity is
#    enforced by scripts/repo_guard (snapshot + auto-revert), not by agy, on top of
#    the disposable-container trust model.
#  - PRIMARY Pro, FALLBACK Flash. Now that --model binds, the fallback genuinely
#    switches: Gemini 3.1 Pro (High) primary (best quality), Gemini 3.5 Flash (High)
#    fallback (faster, finishes comfortably inside the budget, gave equivalent
#    findings in testing). Verify names with `agy models`; do NOT use agy's
#    Claude/GPT-OSS entries. Update these lines when a new top model ships.
#  - "Error: timed out waiting for response" IS --print-timeout firing. agy prints
#    that line and exits 0 (a clean exit, NOT a hang), leaving truncated output with
#    no findings block. attempt() therefore treats output that ENDS with that line
#    as a failure (see agy_ended_with_timeout) so the fallback model is tried; a real
#    review that merely QUOTES the phrase mid-content is unaffected (the match is
#    anchored to the final bytes). A genuine hang is caught by `timeout WALL_TIMEOUT`.

set -euo pipefail

PRIMARY_MODEL="Gemini 3.1 Pro (High)"
FALLBACK_MODEL="Gemini 3.5 Flash (High)"
PRINT_TIMEOUT="15m"
WALL_TIMEOUT=1020   # seconds, hard outer bound per attempt (>= PRINT_TIMEOUT 15m + startup slack)

command -v agy >/dev/null 2>&1 || { echo "run_agy: agy CLI not found" >&2; exit 127; }

# True only when agy's output TERMINATES with its --print-timeout error line —
# "Error: " prefix required, anchored to the END of the output (tr drops newlines
# so the regex `$` matches the true end). agy writes this as the last thing when
# --print-timeout fires; a valid review that quotes the phrase has it mid-content,
# not as the final bytes.
agy_ended_with_timeout() {
  tail -c 160 "$1" 2>/dev/null | tr -d '\n' \
    | grep -qE 'Error: timed out waiting for response[[:space:]]*$'
}

promptfile="$(mktemp /tmp/agy_prompt.XXXXXX)"
outfile="$(mktemp /tmp/agy_out.XXXXXX)"
trap 'rm -f "$promptfile" "$outfile"' EXIT

if [ "$#" -ge 1 ]; then
  printf '%s' "$1" > "$promptfile"
else
  cat > "$promptfile"   # prompt on stdin; cat reaches EOF here
fi

# Run one model. agy's stdout -> $outfile (relayed verbatim by the caller on the
# chosen attempt); its stderr stays on our stderr (the caller captures it).
# Returns 0 on success, non-zero to trigger the fallback. Two failure paths: the
# attempt exits non-zero (agy error, or `timeout` killing a true hang), OR it exits
# 0 but its output ENDS with agy's --print-timeout error line (a fired print-timeout
# is a clean exit-0 with truncated, block-less output — see agy_ended_with_timeout).
attempt() {
  local model="$1" rc
  : > "$outfile"
  # NO bare `--print`: agy's --print TAKES THE PROMPT AS ITS ARGUMENT, so a bare
  # `--print` with the prompt on stdin swallows the following flag (--model) and
  # desyncs parsing — --model AND --print-timeout get dropped and agy silently
  # falls back to the ~/.gemini default model + the 5m default print cap. Feed the
  # prompt on stdin with NO --print (agy reads piped stdin non-interactively) so
  # the flags below actually bind. --print-timeout uses the =form for safety.
  if timeout "$WALL_TIMEOUT" agy \
       --print-timeout="$PRINT_TIMEOUT" \
       --model "$model" \
       --dangerously-skip-permissions \
       < "$promptfile" > "$outfile"; then rc=0; else rc=$?; fi
  # A fired --print-timeout makes agy print its error line and exit 0 (a clean
  # exit, not a hang). Treat that truncated output as a failure so the fallback
  # model is tried — otherwise a timed-out attempt looks like success and the
  # caller relays output with no findings block.
  if agy_ended_with_timeout "$outfile"; then return 1; fi
  return "$rc"
}

if attempt "$PRIMARY_MODEL"; then
  cat "$outfile"
  exit 0
fi

echo "run_agy: primary model ('$PRIMARY_MODEL') failed (timeout/error); retrying with fallback ('$FALLBACK_MODEL')" >&2

if attempt "$FALLBACK_MODEL"; then
  cat "$outfile"
  exit 0
fi

# Both failed. Relay the last attempt's output (so the caller logs agy's own
# message) and exit non-zero so the referee degrades the Gemini seat.
cat "$outfile"
echo "run_agy: both primary ('$PRIMARY_MODEL') and fallback ('$FALLBACK_MODEL') models failed" >&2
exit 1
