#!/usr/bin/env bash
# reopen — revive a FINISHED run's leftover issues for another debate cycle (the
# engine behind `panel-review:continue`). Counterpart to init_run: init_run
# starts a run; reopen revives a finished one in place.
#
# Usage: reopen --id ID --category both|unresolved|contested
#
# Resets the selected issues + global round counters via `index reopen` (the only
# writer of index.json), then CLEARS /tmp/<ID>/sweeps/. Afterwards the run looks
# like a Round-0-gated run (issues present, no committed sweeps) and mode=resume
# starts a clean debate at round 1.
#
# Crash safety comes from the run_epoch counter, NOT from the order of these two
# steps: `index reopen` bumps .run_epoch in the SAME atomic mutate that clears
# committed_rounds. Any sweep dir left over from the previous cycle still carries
# the OLD epoch in its .epoch stamp, so on resume `sweep begin` wipes it (stamp
# mismatch) and `index commit-sweep` rejects a stale-epoch commit. A crash between
# the index reset and the rm below is therefore harmless — the leftover dir cannot
# be replayed against the new epoch.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"; . "$here/_panel_common.sh"

id="" category=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --id) id="$2"; shift 2;;
    --category) category="$2"; shift 2;;
    *) echo "reopen: unknown arg: $1" >&2; exit 2;;
  esac
done
panel_require_id "$id"
case "$category" in both|unresolved|contested) ;; *) echo "reopen: --category must be both|unresolved|contested" >&2; exit 2;; esac
[ -s "/tmp/$id/index.json" ] || { echo "reopen: no index for $id" >&2; exit 1; }

# index.json mutation first (propagates exit 3 = nothing matched, leaving the run
# untouched), bumping run_epoch atomically with clearing committed_rounds.
"$here/index" reopen "$id" "$category"

# Drop stale debate checkpoints so resume starts the debate clean. /tmp/$id is
# validated by panel_require_id above; only this subtree is removed. (run_epoch
# already invalidates any dir a crash leaves behind here — see the header.)
rm -rf -- "/tmp/$id/sweeps"
mkdir -p "/tmp/$id/sweeps"

printf '%s\n' "$id"
