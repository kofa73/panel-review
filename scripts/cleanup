#!/usr/bin/env bash
# cleanup — remove a run's artifacts. Call ONLY after the verdict is fully
# produced and persisted (an interrupted run must keep them for resume).
# Removes the workdir marker, the /tmp state, and the .git/info/exclude entry
# (only if no other runs remain). Validates <ID> before any rm -rf.
#
# Usage: cleanup --id ID --workdir DIR
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"; . "$here/_panel_common.sh"

id="" workdir=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --id) id="$2"; shift 2;;
    --workdir) workdir="$2"; shift 2;;
    *) echo "cleanup: unknown arg: $1" >&2; exit 2;;
  esac
done
panel_require_id "$id"; [ -n "$workdir" ] || { echo "cleanup: need --workdir" >&2; exit 2; }

marker="$workdir/.panel-review/$id"
# Guard: only ever rm a path that ends in our validated id, under the expected roots.
[ -d "$marker" ] && rm -rf -- "$marker"
[ -d "/tmp/$id" ] && rm -rf -- "/tmp/$id"

# The pre-cleanup verdict snapshot (persisted before cleanup for crash-safety) is a
# sibling FILE of the run dir, not inside it. Remove it too — otherwise it lingers,
# and because the "remaining" check below counts only sub-DIRS it would still drop
# the git-exclude entry, leaving verdict-<id>.md as a visible untracked file.
verdict="$workdir/.panel-review/verdict-$id.md"
[ -f "$verdict" ] && rm -f -- "$verdict"

# Deliberately NOT removed here: /tmp/$id.md, the durable verdict artifact
# (write_verdict_artifact) — a sibling FILE of /tmp/$id/, outside both rm -rf
# targets above by construction. It must outlive cleanup so the user keeps a
# copy after the session tears down; do not add a line to delete it.

base="$workdir/.panel-review"
if [ -d "$base" ]; then
  remaining=0; for d in "$base"/*/; do [ -d "$d" ] && remaining=1; done
  if [ "$remaining" -eq 0 ]; then
    # No run dirs left. Clear the whole base — it may still hold worktree-wide
    # stray files (the .init.lock, a leftover verdict snapshot) that a bare rmdir
    # would choke on, leaving the dir un-excluded and visible in git status.
    rm -rf -- "$base"
    panel_git_exclude_del "$workdir" ".panel-review/"
  fi
fi
