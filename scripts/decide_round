#!/usr/bin/env python3
"""Mechanically build one debate round's commit-sweep payload."""

import json
import os
import re
import sys


here = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, here)
import panel_common  # noqa: E402


BLINDNESS_PATTERN = r"\b(codex|gpt|gemini|claude)\b|\b(an)?other (reviewer|seat|model|ai)s?\b|\b(all( ?(three|3))?|both|two|the other) (seats|reviewers|models|ais)\b|\b(seats?|reviewers?|models?|the others?|we|every(one|body)) (all )?(agree|disagree|concur)\b|\b[0-9]+ ?(/|of) ?(the )?(three|3) (seats|reviewers)\b"
BLINDNESS_RE = re.compile(BLINDNESS_PATTERN, re.IGNORECASE)
ENUM_FIELDS = ("severity", "location", "category")


def compact(value):
    return json.dumps(value, separators=(",", ":"), ensure_ascii=False)


def fail(message, code):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def jq_display(value):
    if value is None:
        return "null"
    if value is True:
        return "true"
    if value is False:
        return "false"
    if isinstance(value, str):
        return value
    return compact(value)


def split_seats(value):
    return value.split()


def load_json(path):
    with open(path, encoding="utf-8") as handle:
        return json.load(handle)


def load_stances(path):
    with open(path, encoding="utf-8") as handle:
        return [json.loads(line) for line in handle if line.strip()]


def manifest_limit(manifest, name, default):
    value = manifest.get("limits", {}).get(name, default) if isinstance(manifest, dict) else default
    return value if type(value) is int else default


def revision_value(stance, issue, field):
    revision = stance.get("revision")
    if isinstance(revision, dict) and field in revision:
        value = revision[field]
        if value is not None and value is not False:
            return value
    return issue.get(field)


def unique_values(values):
    result = []
    for value in values:
        if value not in result:
            result.append(value)
    return result


def integrity_errors(index, stances, engaged, configured):
    open_ids = [issue.get("id") for issue in index.get("issues", []) if issue.get("state") == "open"]
    errors = []
    for seat in engaged:
        if seat not in configured:
            errors.append(f"engaged seat not in configured panel: {seat}")

    sources = unique_values([stance.get("_source") for stance in stances])
    for source in sources:
        if source not in engaged:
            errors.append(f"unknown _source (not an engaged seat): {jq_display(source)}")

    for seat in engaged:
        for issue_id in open_ids:
            count = sum(
                stance.get("_source") == seat and stance.get("id") == issue_id for stance in stances
            )
            if count != 1:
                errors.append(f"expected exactly 1 stance for seat={seat} issue={issue_id}, got {count}")
    return errors


def blindness_errors(stances):
    errors = []
    for stance in stances:
        evidence = stance.get("new_evidence")
        values = [("rationale", stance.get("rationale"))]
        if isinstance(evidence, dict):
            values.extend(
                [
                    ("new_evidence.assertion", evidence.get("assertion")),
                    ("new_evidence.precondition", evidence.get("precondition")),
                    ("new_evidence.impact", evidence.get("impact")),
                ]
            )
            location = evidence.get("location")
            if isinstance(location, list):
                values.extend(("new_evidence.location", value) for value in location)
            else:
                values.append(("new_evidence.location", location))
        for field, value in values:
            if isinstance(value, str) and BLINDNESS_RE.search(value):
                errors.append(
                    f"seat={jq_display(stance.get('_source'))} issue={jq_display(stance.get('id'))} "
                    f"field={field}: blindness marker in promoted text"
                )
    return errors


def decide(index, stances, round_number, issue_rounds, max_rounds, configured, evaluated):
    decisions = []
    for issue in index.get("issues", []):
        if issue.get("state") != "open":
            continue
        issue_id = issue.get("id")
        issue_stances = [stance for stance in stances if stance.get("id") == issue_id]
        seats_now = sorted(unique_values([stance.get("_source") for stance in issue_stances]))
        n = len(issue_stances)
        stance_names = [stance.get("stance") for stance in issue_stances]
        supporting = [
            stance
            for stance in issue_stances
            if stance.get("stance") in ("support", "support_with_revision")
        ]

        fields = []
        for field in ENUM_FIELDS:
            effective = unique_values([revision_value(stance, issue, field) for stance in supporting])
            fields.append((field, len(effective) == 1, effective[0] if len(effective) == 1 else None))
        adopt = {field: value for field, converged, value in fields if converged and value != issue.get(field)}
        enum_conflict = any(not converged for _, converged, _ in fields)

        claim_props = []
        for stance in issue_stances:
            revision = stance.get("revision")
            if stance.get("stance") == "support_with_revision" and isinstance(revision, dict):
                claim = revision.get("claim")
                if claim is not None:
                    claim_props.append({"seat": stance.get("_source"), "claim": claim})

        evidence = []
        for stance in issue_stances:
            if stance.get("stance") in ("reject", "support_with_revision"):
                assertion = stance.get("rationale") or ""
                if isinstance(assertion, str) and assertion:
                    evidence.append({"side": "contra", "point": {"location": "analysis", "assertion": assertion}})
        for stance in issue_stances:
            if stance.get("new_evidence") is not None:
                evidence.append(
                    {
                        "side": "contra" if stance.get("stance") == "reject" else "pro",
                        "point": stance.get("new_evidence"),
                    }
                )

        peer_now = n >= 2
        all_reject = peer_now and all(name == "reject" for name in stance_names)
        all_support = peer_now and all(name in ("support", "support_with_revision") for name in stance_names)
        mixed = peer_now and not all_reject and not all_support
        post_rounds_debated = (issue.get("rounds_debated") or 0) + (1 if peer_now else 0)
        at_limit = post_rounds_debated >= issue_rounds or round_number >= max_rounds
        peer_ever = issue.get("peer_reviewed") is True or peer_now
        eval_cum = sorted(unique_values((evaluated.get(issue_id) or []) + seats_now))
        covered = all(seat in eval_cum for seat in configured)

        if n < 2:
            state = "contested" if at_limit and peer_ever else ("unresolved" if at_limit else "open")
        elif all_reject:
            state = "rejected"
        elif all_support:
            state = "accepted" if not enum_conflict or at_limit else "open"
        elif mixed:
            state = "contested" if at_limit else "open"
        else:
            state = "open"

        decisions.append(
            {
                "id": issue_id,
                "bump": peer_now,
                "state": state,
                "peer": peer_now,
                "all_support": all_support,
                "adopt": adopt,
                "set_detail": all_support and enum_conflict and at_limit,
                "evidence": evidence,
                "claim_props": claim_props,
                "eval_cum": eval_cum,
                "fully_vetted": covered and peer_now,
            }
        )

    payload0 = {
        "bump": [decision["id"] for decision in decisions if decision["bump"]],
        "set_state": [
            {"id": decision["id"], "state": decision["state"]}
            for decision in decisions
            if decision["state"] != "open"
        ],
        "set_flag": (
            [
                {"id": decision["id"], "flag": "peer_reviewed", "value": True}
                for decision in decisions
                if decision["peer"]
            ]
            + [
                {"id": decision["id"], "flag": "fully_vetted", "value": True}
                for decision in decisions
                if decision["fully_vetted"]
            ]
            + [
                {"id": decision["id"], "flag": "detail_contested", "value": True}
                for decision in decisions
                if decision["set_detail"]
            ]
        ),
        "revise": [
            {"id": decision["id"], "fields": decision["adopt"]}
            for decision in decisions
            if decision["all_support"] and decision["adopt"]
        ],
        "add_evidence": [
            {"id": decision["id"], "side": entry["side"], "point": entry["point"]}
            for decision in decisions
            for entry in decision["evidence"]
        ],
    }
    payload = {key: value for key, value in payload0.items() if value}
    advice = {
        "prose_revisions": [
            {"id": decision["id"], "proposals": decision["claim_props"]}
            for decision in decisions
            if decision["claim_props"]
        ]
    }
    evaluated_by = {decision["id"]: decision["eval_cum"] for decision in decisions}
    return payload, advice, evaluated_by


def main():
    args = sys.argv[1:]
    values = {"id": "", "round": "", "configured": "", "engaged": "", "stances": "", "advice": ""}
    options = {f"--{key}": key for key in values}
    while args:
        option = args.pop(0)
        if option not in options:
            fail(f"decide_round: unknown arg: {option}", 2)
        if not args:
            fail(f"decide_round: unknown arg: {option}", 2)
        values[options[option]] = args.pop(0)

    panel_common.panel_require_id(values["id"])
    if not re.fullmatch(r"[0-9]+", values["round"]):
        fail("decide_round: --round must be an integer", 2)
    if not values["engaged"]:
        fail("decide_round: --engaged required", 2)
    if not values["stances"]:
        fail("decide_round: --stances required", 2)
    if not os.path.isfile(values["stances"]):
        fail(f"decide_round: no such stances file: {values['stances']}", 1)

    index_path = os.path.join("/tmp", values["id"], "index.json")
    if not os.path.isfile(index_path):
        fail(f"decide_round: no index for {values['id']}", 1)
    manifest_path = os.path.join("/tmp", values["id"], "manifest.json")
    manifest = {}
    if os.path.isfile(manifest_path):
        try:
            manifest = load_json(manifest_path)
        except (OSError, json.JSONDecodeError):
            manifest = {}
    issue_rounds = manifest_limit(manifest, "issue_rounds", 2)
    max_rounds = manifest_limit(manifest, "max_rounds", 4)

    index = load_json(index_path)
    evaluated = index.get("evaluated_by") or {}
    if not isinstance(evaluated, dict):
        fail("decide_round: invalid index evaluated_by", 1)
    stances = load_stances(values["stances"])
    configured = split_seats(values["configured"])
    engaged = split_seats(values["engaged"])

    errors = integrity_errors(index, stances, engaged, configured)
    if errors:
        print("decide_round: stance-integrity violation(s):", file=sys.stderr)
        for error in errors:
            print(f"  - {error}", file=sys.stderr)
        raise SystemExit(3)

    errors = blindness_errors(stances)
    if errors:
        print("decide_round: blindness violation(s) (seat identity / tally in promoted evidence):", file=sys.stderr)
        for error in errors:
            print(f"  - {error}", file=sys.stderr)
        raise SystemExit(5)

    payload, advice, evaluated_by = decide(
        index,
        stances,
        int(values["round"]),
        issue_rounds,
        max_rounds,
        configured,
        evaluated,
    )
    if values["advice"]:
        with open(values["advice"], "w", encoding="utf-8") as handle:
            json.dump(advice, handle, ensure_ascii=False)
            handle.write("\n")
    payload["evaluated_by"] = evaluated_by
    print(compact(payload))


if __name__ == "__main__":
    main()
