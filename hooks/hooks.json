{
  "description": "Keep panel-review subagent completion results on their fixed status interfaces.",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "^panel-review:(panel-review-claude-seat|panel-review-referee)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/enforce_agent_status_stub\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
