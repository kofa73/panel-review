#!/usr/bin/env python3
"""Gate panel-review subagent completion on an exact status response."""

import json
from pathlib import Path
import re
import sys


CLAUDE_SEAT = "panel-review:panel-review-claude-seat"
CLAUDE_SEAT_STATUSES = ("CLAUDE_SEAT_RAW_WRITTEN", "CLAUDE_SEAT_RAW_FAILED")
REFEREE = "panel-review:panel-review-referee"
REFEREE_STATUSES = (
    "PANEL_VERDICT_READY",
    "PANEL_VERDICT_WRITE_FAILED",
    "PANEL_REVIEW_FAILED",
)


def prompt_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        return "\n".join(
            block.get("text", "")
            for block in content
            if isinstance(block, dict) and block.get("type") == "text"
        )
    return ""


def expected_referee_id(transcript_path):
    """Read the original Agent task, which is the only stable source after referee cleanup."""
    try:
        with Path(transcript_path).open(encoding="utf-8") as transcript:
            for line in transcript:
                entry = json.loads(line)
                if entry.get("type") != "user" or entry.get("isMeta"):
                    continue
                message = entry.get("message", {})
                text = prompt_text(message.get("content"))
                matches = re.findall(r"(?m)^id=([A-Za-z0-9._-]+)$", text)
                if len(matches) == 1 and matches[0] not in {".", ".."}:
                    return matches[0]
                return None
    except (OSError, ValueError, TypeError):
        return None
    return None


try:
    payload = json.load(sys.stdin)
except (json.JSONDecodeError, OSError, TypeError, ValueError):
    print(
        "panel-review status hook could not validate the Agent response; return only its fixed "
        "status stub",
        file=sys.stderr,
    )
    raise SystemExit(2)
agent_type = payload.get("agent_type")
if agent_type not in {CLAUDE_SEAT, REFEREE}:
    raise SystemExit(0)

message = payload.get("last_assistant_message", "")
if agent_type == CLAUDE_SEAT:
    allowed = message in CLAUDE_SEAT_STATUSES
    reason = (
        "Return exactly CLAUDE_SEAT_RAW_WRITTEN or CLAUDE_SEAT_RAW_FAILED, "
        "with no surrounding text. Do not repeat the completed review or write operation."
    )
else:
    expected_id = expected_referee_id(payload.get("agent_transcript_path", ""))
    allowed = expected_id is not None and message in {
        f"{status} id={expected_id}" for status in REFEREE_STATUSES
    }
    if expected_id is None:
        reason = (
            "Return exactly one fixed panel-review status stub with the run ID from the original "
            "task prompt and no surrounding text. Do not repeat review or verdict content."
        )
    else:
        reason = (
            "Return exactly PANEL_VERDICT_READY, PANEL_VERDICT_WRITE_FAILED, or "
            f"PANEL_REVIEW_FAILED followed by id={expected_id}, with no surrounding text. "
            "Do not repeat review or verdict content."
        )

if allowed:
    raise SystemExit(0)

# The rejected response stays inside the subagent transcript. Keep it out of the feedback so the
# hook itself cannot copy raw review prose into the parent-facing completion path.
json.dump(
    {
        "decision": "block",
        "reason": reason,
    },
    sys.stdout,
)
