#!/usr/bin/env bash
# parse_block — extract a fenced ```<tag> JSONL block and emit only the VALID
# JSON objects, one per line. Malformed lines are dropped with a stderr note
# (a seat that emits junk for one item must not crash the run — that item just
# doesn't count). Replaces extract_findings; used for findings / new_findings /
# stances.
#
# Usage: parse_block <tag> <rawfile> [source-label]
#   With a source-label, each object is tagged for the referee's PRIVATE record:
#     _source = label,  fid = "<label>-<N>"  (stable handle; never shown on a card)
#
# Exit codes:
#   0  block PRESENT (either empty/whitespace-only OR >=1 valid objects emitted).
#   4  block ABSENT (the seat emitted no ```<tag> fence at all) — a malfunctioned
#      /refusing seat, NOT "found nothing". Lets the loop tell the two apart.
#   5  block PRESENT with non-whitespace content but ZERO valid objects parsed.
#   1  missing input file.  127  jq not found.  2  usage.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
command -v jq >/dev/null 2>&1 || { echo "parse_block: jq not found" >&2; exit 127; }

[ "$#" -ge 2 ] || { echo "usage: parse_block <tag> <rawfile> [label]" >&2; exit 2; }
tag="$1"; file="$2"; label="${3-}"
[ -f "$file" ] || { echo "parse_block: no such file: $file" >&2; exit 1; }

# Distinguish "no block" from "empty block" up front.
if ! "$here/extract_block" --present "$tag" "$file"; then
  echo "parse_block: no '$tag' block in output (seat produced none)" >&2
  exit 4
fi

# Per-tag schema: an object must carry the tag's REQUIRED fields to count, so a
# truncated/garbled line ("just an object") is dropped rather than mistaken for a
# real finding/stance. (Per-card stance cardinality is the referee's job, not ours.)
case "$tag" in
  findings|new_findings) valid='
    def valid_location:
      (type == "string" and length > 0) or (type == "array" and length > 0 and (map(type == "string" and length > 0) | all));
    def valid_point:
      type == "object" and
      (.assertion | type == "string") and
      (has("location") and (.location | valid_location)) and
      ((has("precondition") | not) or (.precondition | type == "string")) and
      ((has("impact") | not) or (.impact | type == "string"));
    select(type == "object" and (.claim|type=="string") and (has("location") and (.location|valid_location))) |
    select(.category | type == "string" and IN("security", "correctness", "performance", "maintainability", "style")) |
    select(.severity | type == "string" and IN("critical", "high", "medium", "low", "style")) |
    .points = (if has("points") then .points else [] end) |
    .points |= (if type=="array" then map(select(valid_point)) elif valid_point then [.] else [] end) |
    select(.points | length > 0)';;
  stances) valid='
    def valid_location:
      (type == "string" and length > 0) or (type == "array" and length > 0 and (map(type == "string" and length > 0) | all));
    def valid_point:
      type == "object" and
      (.assertion | type == "string") and
      (has("location") and (.location | valid_location)) and
      ((has("precondition") | not) or (.precondition | type == "string")) and
      ((has("impact") | not) or (.impact | type == "string"));
    select(type=="object" and (.id|type=="string") and ((.stance|type=="string") and (.stance|test("^(support|support_with_revision|reject)$")))) |
    (if has("revision") and (.revision | type == "object") then
      .revision |= (
        (if has("category") and (.category | type == "string" and IN("security", "correctness", "performance", "maintainability", "style") | not) then del(.category) else . end) |
        (if has("severity") and (.severity | type == "string" and IN("critical", "high", "medium", "low", "style") | not) then del(.severity) else . end) |
        (if has("claim") and (.claim | type == "string" | not) then del(.claim) else . end) |
        (if has("location") and (.location | valid_location | not) then del(.location) else . end) |
        with_entries(select(.key | IN("category", "severity", "claim", "location")))
      ) | (if .revision == {} then del(.revision) else . end)
    else del(.revision) end) |
    (if has("new_evidence") then (if (.new_evidence | type == "object") then .new_evidence |= select(valid_point) else del(.new_evidence) end) | (if .new_evidence == null then del(.new_evidence) else . end) else . end) |
    (if has("evidence") then (if (.evidence | type == "object") then .evidence |= select(valid_point) else del(.evidence) end) | (if .evidence == null then del(.evidence) else . end) else . end)';;
  *)                     valid='select(type=="object")';;
esac

emit() { # validated object on stdin -> stdout, optionally tagged for the referee
  if [ -n "$label" ]; then
    jq -c --arg s "$label" --argjson n "$1" '. + {_source:$s, fid:($s+"-"+($n|tostring))}'
  else
    jq -c .
  fi
}

n=0; bad=0
raw="$("$here/extract_block" "$tag" "$file")"

# Empty-but-present is valid and exits 0.
if [ -z "${raw//[[:space:]]/}" ]; then
  exit 0
fi

parsed_whole=0
if parsed="$(printf '%s' "$raw" | jq -c 'if type=="array" then .[] else . end' 2>/dev/null)"; then
  parsed_whole=1
  while IFS= read -r line; do
    [ -n "${line//[[:space:]]/}" ] || continue
    if t="$(printf '%s' "$line" | jq -c -e "$valid" 2>/dev/null)"; then
      n=$((n+1)); printf '%s' "$t" | emit "$n"
    else
      bad=$((bad+1))
    fi
  done <<< "$parsed"
fi

if [ "$parsed_whole" -eq 0 ]; then
  # Fall back to line-by-line heuristic if whole-block parsing fails.
  while IFS= read -r line; do
    [ -n "${line//[[:space:]]/}" ] || continue
    if t="$(printf '%s' "$line" | jq -c -e "$valid" 2>/dev/null)"; then
      n=$((n+1)); printf '%s' "$t" | emit "$n"
    else
      bad=$((bad+1))
    fi
  done <<< "$raw"
fi

[ "$bad" -eq 0 ] || echo "parse_block: skipped $bad malformed line(s) in '$tag'" >&2

if [ "$n" -eq 0 ]; then
  echo "parse_block: block present with non-whitespace content but zero valid objects parsed" >&2
  exit 5
fi

exit 0
