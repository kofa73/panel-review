#!/usr/bin/env bash
# index — the only writer of /tmp/<ID>/index.json (the canonical issue index).
# Counter/state/flag math lives HERE (deterministic), not in the protocol prose.
# Every mutation is an atomic rewrite and bumps the issue's card_rev so the
# projected card can be detected as stale.
#
# Subcommands:
#   index get   <ID>                          print index.json
#   index put   <ID>                          replace index.json from stdin (validated)
#   index issue <ID> <issue-id>               print one issue record (or empty)
#   index bump  <ID> <issue-id>               +1 rounds_debated, +1 card_rev
#   index state <ID> <issue-id> <state>       set .state, +1 card_rev
#   index flag  <ID> <issue-id> <flag> <bool> set a boolean flag, +1 card_rev
#                 (flag in: peer_reviewed|fully_vetted|detail_contested)
#   index reopen <ID> both|unresolved|contested
#                 Re-open leftover issues for another debate cycle: matching issues
#                 -> state=open, rounds_debated=0, vetting flags false; global round=0,
#                 committed_rounds=[]. Keeps evidence. Exit 3 if no such issue.
#   index commit-round <ID> <round-int> <iids-json-array>
#                 idempotently record a committed sweep: if <round> is already in
#                 .committed_rounds, no-op; else append it, set .round, and bump
#                 (rounds_debated,card_rev) for each issue id in the array. The
#                 committed_rounds guard makes a re-run after a crash a no-op.
#   index commit-sweep <ID> <round-int>   (payload JSON on stdin)
#                 The crash-safe way to apply a whole debate round in ONE atomic,
#                 idempotent step. Guarded by .committed_rounds exactly like
#                 commit-round, but applies the round's ENTIRE decision set at once
#                 so nothing touches index.json until the single commit (a crash
#                 before it leaves round N wholly unapplied; a re-run is a no-op).
#                 Payload (all keys optional):
#                   {"add_issues":[<full issue record>...],
#                    "bump":["i1",...],                       // reached >=2 engaged -> +rounds_debated
#                    "set_state":[{"id","state"}],
#                    "set_flag":[{"id","flag","value"}],      // flag in peer_reviewed|fully_vetted|detail_contested
#                    "add_evidence":[{"id","side":"pro|contra","point":{...}}],
#                    "revise":[{"id","fields":{severity?,claim?,location?,category?}}]}
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"; . "$here/_panel_common.sh"
command -v jq >/dev/null 2>&1 || { echo "index: jq not found" >&2; exit 127; }

cmd="${1-}"; id="${2-}"; panel_require_id "$id"
f="/tmp/$id/index.json"
[ -f "$f" ] || { echo "index: no index for $id" >&2; exit 1; }

# Serialize mutations on index.json for a given run ID.
case "$cmd" in
  put|bump|state|flag|commit-round|commit-sweep|reopen)
    mkdir -p "/tmp/$id"
    touch "/tmp/$id/.index.lock"
    exec 9>"/tmp/$id/.index.lock"
    flock -x 9
    ;;
esac

mutate() { # jq-filter on the index file -> atomic rewrite, transactional.
  # NEVER pipe jq straight into panel_atomic_write: if jq fails mid-pipe, the
  # writer still receives EOF and renames an EMPTY file over index.json,
  # destroying the run. Stage jq output in a temp first; only on jq success
  # do we atomically install it (panel_atomic_write keeps the .bak rotation).
  local filter="$1"; shift
  local tmp; tmp="$(mktemp "/tmp/$id/.idx.XXXXXX")"
  if jq "$@" "$filter" "$f" > "$tmp"; then
    panel_atomic_write "$f" < "$tmp"; rm -f "$tmp"
  else
    rm -f "$tmp"; echo "index: mutate failed (filter rejected or bad JSON); index.json left intact" >&2; exit 1
  fi
}

case "$cmd" in
  get)   cat "$f" ;;
  issue) jq -c --arg i "$3" '.issues[] | select(.id==$i)' "$f" ;;
  put)   tmp="$(cat)"; printf '%s' "$tmp" | jq -e . >/dev/null || { echo "index put: invalid JSON" >&2; exit 1; }
         printf '%s' "$tmp" | panel_atomic_write "$f" ;;
  bump)  mutate '(.issues[] | select(.id==$i)) |= (.rounds_debated = ((.rounds_debated//0)+1) | .card_rev = ((.card_rev//0)+1))' --arg i "$3" ;;
  state) mutate '(.issues[] | select(.id==$i)) |= (.state=$s | .card_rev=((.card_rev//0)+1))' --arg i "$3" --arg s "$4" ;;
  flag)  case "$4" in peer_reviewed|fully_vetted|detail_contested) ;; *) echo "index flag: bad flag $4" >&2; exit 2;; esac
         case "$5" in true) v=true;; false) v=false;; *) echo "index flag: bool must be true|false" >&2; exit 2;; esac
         mutate "(.issues[] | select(.id==\$i)) |= (.$4=\$v | .card_rev=((.card_rev//0)+1))" --arg i "$3" --argjson v "$v" ;;
  commit-round)
         r="${3-}"; iids="${4-}"
         case "$r" in ''|*[!0-9]*) echo "index commit-round: round must be an integer" >&2; exit 2;; esac
         [ -n "$iids" ] || { echo "index commit-round: need <iids-json-array>" >&2; exit 2; }
         printf '%s' "$iids" | jq -e 'type=="array"' >/dev/null 2>&1 || { echo "index commit-round: iids must be a JSON array" >&2; exit 2; }
         mutate 'if ((.committed_rounds // []) | any(. == $r)) then .
                 else .committed_rounds = ((.committed_rounds // []) + [$r])
                      | .round = $r
                      | (.issues[] | select(.id as $x | ($iids | index($x)) != null)) |=
                          (.rounds_debated = ((.rounds_debated//0)+1) | .card_rev = ((.card_rev//0)+1))
                 end' --argjson r "$r" --argjson iids "$iids" ;;
	  commit-sweep)
	         r="${3-}"
	         case "$r" in ''|*[!0-9]*) echo "index commit-sweep: round must be an integer" >&2; exit 2;; esac
	         p="$(cat)"; [ -n "$p" ] || p='{}'
	         printf '%s' "$p" | jq -e 'type=="object"' >/dev/null 2>&1 || { echo "index commit-sweep: payload must be a JSON object" >&2; exit 2; }
	         printf '%s' "$p" | jq -e '
	           (.add_issues // []) | type=="array" and all(.[]; (.id|type=="string") and (.id|test("^[A-Za-z0-9._-]+$")) and (.id!=".") and (.id!=".."))
	         ' >/dev/null 2>&1 || { echo "index commit-sweep: add_issues contains missing or invalid id" >&2; exit 2; }
	         mutate 'if ((.committed_rounds // []) | any(. == $r)) then .
	                 else .committed_rounds = ((.committed_rounds // []) + [$r])
                   | .round = $r
                   | .issues = (.issues + ($p.add_issues // []))
                   | (.issues[] | select(.id as $x | (($p.bump // []) | index($x)) != null)) |=
                       (.rounds_debated = ((.rounds_debated//0)+1) | .card_rev = ((.card_rev//0)+1))
                   | reduce ($p.set_state // [])[] as $s (.;
                       (.issues[] | select(.id==$s.id)) |= (.state=$s.state | .card_rev=((.card_rev//0)+1)))
                   | reduce ($p.set_flag // [])[] as $g (.;
                       if (["peer_reviewed","fully_vetted","detail_contested"] | index($g.flag)) != null
                       then (.issues[] | select(.id==$g.id)) |= (.[$g.flag]=$g.value | .card_rev=((.card_rev//0)+1))
                       else . end)
                   | reduce ($p.add_evidence // [])[] as $e (.;
                       (.issues[] | select(.id==$e.id)) |=
                         (if $e.side=="pro"
                          then .evidence_pro = ((.evidence_pro//[]) + [$e.point])
                          else .evidence_contra = ((.evidence_contra//[]) + [$e.point]) end
                          | .card_rev=((.card_rev//0)+1)))
                   | reduce ($p.revise // [])[] as $v (.;
                       (.issues[] | select(.id==$v.id)) |=
                         (.severity = ($v.fields.severity // .severity)
                          | .claim    = ($v.fields.claim // .claim)
                          | .location = ($v.fields.location // .location)
                          | .category = ($v.fields.category // .category)
                          | .card_rev=((.card_rev//0)+1)))
                 end' --argjson r "$r" --argjson p "$p" ;;
  reopen)
         category="${3-}"
         case "$category" in both|unresolved|contested) ;; *) echo "index reopen: category must be both|unresolved|contested" >&2; exit 2;; esac
         # Count matches first so the caller can distinguish "nothing to do" (exit 3).
         n="$(jq --arg category "$category" '[.issues[] | select(
                ($category=="both" and (.state=="unresolved" or .state=="contested"))
                or ($category=="unresolved" and .state=="unresolved")
                or ($category=="contested" and .state=="contested"))] | length' "$f")"
         if [ "$n" -eq 0 ]; then echo "index reopen: no $category issue to re-open" >&2; exit 3; fi
         # Re-open selected issues + reset global counters; keep evidence; bump card_rev.
         mutate '
           .committed_rounds=[] | .round=0
           | (.issues[] | select(
               ($category=="both" and (.state=="unresolved" or .state=="contested"))
               or ($category=="unresolved" and .state=="unresolved")
               or ($category=="contested" and .state=="contested")
             )) |= (.state="open" | .rounds_debated=0
                    | .peer_reviewed=false | .fully_vetted=false | .detail_contested=false
                    | .card_rev=((.card_rev//0)+1))
         ' --arg category "$category" ;;
  *) echo "usage: index {get|put|issue|bump|state|flag|commit-round|commit-sweep|reopen} <ID> ..." >&2; exit 2 ;;
esac
